def theta_to_u(theta_deg):
    return np.sin(np.deg2rad(theta_deg))


def u_to_theta_deg(u):
    u = np.clip(np.asarray(u, dtype=float), -0.999999, 0.999999)
    return np.rad2deg(np.arcsin(u))


def build_qh_model_from_support(support_deg, powers, sigma_n2_hat, theta_s_bar, M):
    support_deg = np.asarray(support_deg, dtype=float).reshape(-1)
    powers = np.asarray(powers, dtype=float).reshape(-1)

    a_bar = steering_vector(theta_s_bar, M)

    Rs = np.zeros((M, M), dtype=complex)
    Ri = float(sigma_n2_hat) * np.eye(M, dtype=complex)

    for k, (th, pw) in enumerate(zip(support_deg, powers)):
        a = steering_vector(th, M)
        pw = max(float(pw), 1e-12)

        if k == 0:
            Rs += pw * (a @ a.conj().T)
        else:
            Ri += pw * (a @ a.conj().T)

    Rs = 0.5 * (Rs + Rs.conj().T)
    Ri = 0.5 * (Ri + Ri.conj().T)

    a_hat = Rs @ a_bar
    if np.linalg.norm(a_hat) < 1e-12:
        a_hat = steering_vector(float(support_deg[0]), M)
    a_hat = normalize_vec(a_hat)

    return Rs, Ri, a_hat


def beamformer_surrogate_score(support_deg, powers, sigma_n2_hat, theta_s_bar, M):
    Rs, Ri, a_hat = build_qh_model_from_support(
        support_deg=support_deg,
        powers=powers,
        sigma_n2_hat=sigma_n2_hat,
        theta_s_bar=theta_s_bar,
        M=M,
    )

    w = mvdr_weight(Ri, a_hat)

    num = np.real((w.conj().T @ Rs @ w).item())
    den = np.real((w.conj().T @ Ri @ w).item())

    return num / max(den, 1e-12)


def qh_cobyqa_objective(
    u,
    Rhat,
    init_support_deg,
    desired_sector,
    theta_s_bar,
    sigma_n2_hat,
    min_sep_deg=2.0,
    lambda_sector=5e2,
    lambda_sep=5e2,
    lambda_local=1e-2,
):
    M = Rhat.shape[0]
    theta = u_to_theta_deg(u)

    sec_lo, sec_hi = desired_sector
    penalty = 0.0

    # 干扰角不能进目标扇区
    for k in range(1, len(theta)):
        th = theta[k]
        if sec_lo <= th <= sec_hi:
            dist_to_edge = min(th - sec_lo, sec_hi - th)
            penalty += lambda_sector * (dist_to_edge + 1e-3) ** 2

    # 最小角间隔
    for i in range(len(theta)):
        for j in range(i + 1, len(theta)):
            gap = abs(theta[i] - theta[j])
            if gap < min_sep_deg:
                penalty += lambda_sep * (min_sep_deg - gap) ** 2

    # 不要离粗估计太远
    penalty += lambda_local * np.sum((theta - np.asarray(init_support_deg, dtype=float)) ** 2)

    p_hat = solve_power_ls_nonnegative(
        Rhat=Rhat,
        support_deg=theta,
        M=M,
        sigma_n2_hat=sigma_n2_hat,
        delta=1e-6,
    )

    score = beamformer_surrogate_score(
        support_deg=theta,
        powers=p_hat,
        sigma_n2_hat=sigma_n2_hat,
        theta_s_bar=theta_s_bar,
        M=M,
    )

    return -np.log(max(score, 1e-12)) + penalty


def refine_qh_angles_cobyqa(
    Rhat,
    init_support_deg,
    desired_sector,
    theta_s_bar,
    sigma_n2_hat=None,
    min_sep_deg=2.0,
    target_half_width_deg=3.0,
    interf_half_width_deg=5.0,
    maxiter=120,
):
    M = Rhat.shape[0]
    init_support_deg = np.asarray(init_support_deg, dtype=float).copy()

    if sigma_n2_hat is None:
        sigma_n2_hat = estimate_noise_power(Rhat)

    sec_lo, sec_hi = desired_sector
    x0 = theta_to_u(init_support_deg)

    lb = np.zeros_like(x0, dtype=float)
    ub = np.zeros_like(x0, dtype=float)

    # 目标角：限制在目标扇区内，并在粗估计附近局部优化
    t0 = init_support_deg[0]
    lo_th = max(sec_lo, t0 - target_half_width_deg)
    hi_th = min(sec_hi, t0 + target_half_width_deg)
    lb[0] = theta_to_u(lo_th)
    ub[0] = theta_to_u(hi_th)

    # 干扰角：围绕粗估计做局部优化
    for k in range(1, len(x0)):
        tk = init_support_deg[k]
        lo_th = max(-89.0, tk - interf_half_width_deg)
        hi_th = min(89.0, tk + interf_half_width_deg)
        lb[k] = theta_to_u(lo_th)
        ub[k] = theta_to_u(hi_th)

    bounds = Bounds(lb, ub)

    res = minimize(
        fun=qh_cobyqa_objective,
        x0=x0,
        args=(
            Rhat,
            init_support_deg,
            desired_sector,
            theta_s_bar,
            sigma_n2_hat,
            min_sep_deg,
        ),
        method="COBYQA",
        bounds=bounds,
        options={
            "maxiter": maxiter,
            "disp": False,
        },
    )

    if res.success:
        u_opt = res.x
    else:
        print(f"[COBYQA] status={res.status}, message={res.message}, fallback to init_support")
        u_opt = x0

    support_refined = u_to_theta_deg(u_opt)

    # 保险处理
    support_refined[0] = np.clip(support_refined[0], sec_lo, sec_hi)
    for k in range(1, len(support_refined)):
        if sec_lo <= support_refined[k] <= sec_hi:
            if abs(support_refined[k] - sec_lo) < abs(support_refined[k] - sec_hi):
                support_refined[k] = sec_lo - 1e-3
            else:
                support_refined[k] = sec_hi + 1e-3

    power_refined = solve_power_ls_nonnegative(
        Rhat=Rhat,
        support_deg=support_refined,
        M=M,
        sigma_n2_hat=sigma_n2_hat,
        delta=1e-6,
    )

    return support_refined, power_refined, sigma_n2_hat, res
def qh_ipnc_beamformer(
    Rhat,
    theta_s_bar,
    desired_sector,
    grid_deg=None,
    model_order=None,
    max_order=6,
):
    if grid_deg is None:
        grid_deg = np.linspace(-90, 90, 721)

    M = Rhat.shape[0]
    a_bar = steering_vector(theta_s_bar, M)

    spec = qh_pse_spectrum_from_covariance(
        Rhat=Rhat,
        model_order=model_order,
        max_order=max_order,
        grid_deg=grid_deg,
        kernel_width_deg=1.2,
    )

    # 1) 粗选目标和干扰角
    theta_s0, theta_i0 = select_qh_angles(spec, desired_sector, theta_s_bar, num_interf=2)
    init_support = np.concatenate([[theta_s0], theta_i0])

    support_refined, power_refined, sigma_n2_hat = refine_qh_angles_nomp(
        Rhat=Rhat,
        init_support_deg=init_support,
        desired_sector=desired_sector,
        theta_s_bar=theta_s_bar,
        sigma_n2_hat=spec["sigma_n2_est"],
        n_outer=2,
        target_half_width_deg=2.0,
        interf_half_width_deg=4.0,
        coarse_step_deg=0.2,
        newton_steps=2,
        min_sep_deg=2.0,
    )
    # 3) 用精修后的角度/功率重构 Rs、Ri
    Rs = np.zeros((M, M), dtype=complex)
    Ri = sigma_n2_hat * np.eye(M, dtype=complex)

    for idx, (th, pw) in enumerate(zip(support_refined, power_refined)):
        a = steering_vector(th, M)
        if idx == 0:
            Rs += pw * (a @ a.conj().T)
        else:
            Ri += pw * (a @ a.conj().T)

    Rs = 0.5 * (Rs + Rs.conj().T)
    Ri = 0.5 * (Ri + Ri.conj().T)

    a_hat = Rs @ a_bar
    if np.linalg.norm(a_hat) < 1e-12:
        a_hat = steering_vector(support_refined[0], M)
    a_hat = normalize_vec(a_hat)

    w = mvdr_weight(Ri, a_hat)

    info = {
        "theta_init": init_support,
        "theta_refined": support_refined,
        "power_refined": power_refined,
        "sigma_n2_hat": sigma_n2_hat,
        "spec": spec,
    }
    return w, info, Rs, Ri, a_hat
# ============================================================
# Sparse-reconstruction INCM
# ============================================================
@dataclass
class SparseInfo:
    sigma_n2_hat: float
    support_all_deg: np.ndarray
    support_interf_deg: np.ndarray
    powers_all: np.ndarray
    P_capon: np.ndarray
    P_sparse: np.ndarray


def safe_solve(A, B):
    try:
        return np.linalg.solve(A, B)
    except np.linalg.LinAlgError:
        return np.linalg.pinv(A) @ B


def local_maxima_1d(y):
    y = np.asarray(y).reshape(-1)
    peaks = np.zeros_like(y, dtype=bool)
    if y.size < 3:
        return peaks
    peaks[1:-1] = (y[1:-1] > y[:-2]) & (y[1:-1] >= y[2:])
    return peaks


def outer_vec(a):
    a = np.asarray(a).reshape(-1, 1)
    return (a @ a.conj().T).reshape(-1, order="F")


def solve_power_ls_nonnegative(Rhat, support_deg, M, sigma_n2_hat, delta=1e-5):
    q = len(support_deg)
    if q == 0:
        return np.zeros(0, dtype=float)

    G = np.column_stack([
        outer_vec(steering_vector(th, M)) for th in support_deg
    ]).astype(np.complex128)

    r0 = (Rhat - sigma_n2_hat * np.eye(M)).reshape(-1, order="F").astype(np.complex128)

    active = list(range(q))
    fixed = {}

    while True:
        if len(active) == 0:
            break

        r_mod = r0.copy()
        if fixed:
            G_fix = np.column_stack([G[:, idx] for idx in fixed.keys()])
            p_fix = np.array([fixed[idx] for idx in fixed.keys()], dtype=float)
            r_mod = r_mod - G_fix @ p_fix

        G_act = np.column_stack([G[:, idx] for idx in active])
        p_act, *_ = np.linalg.lstsq(G_act, r_mod, rcond=None)
        p_act = p_act.real

        if np.all(p_act >= 0):
            p = np.zeros(q, dtype=float)
            for idx, val in fixed.items():
                p[idx] = val
            for idx, val in zip(active, p_act):
                p[idx] = max(float(val), delta)
            return p

        worst_local = int(np.argmin(p_act))
        worst_global = active[worst_local]
        fixed[worst_global] = delta
        active.pop(worst_local)

    p = np.zeros(q, dtype=float)
    for idx, val in fixed.items():
        p[idx] = val
    return p


def sparse_ipnc_beamformer(
    Rhat,
    theta_s_bar,
    desired_sector,
    grid_deg,
    delta=1e-5,
    loading=1e-8,
):
    M = Rhat.shape[0]
    a_bar = steering_vector(theta_s_bar, M)

    Rh = 0.5 * (Rhat + Rhat.conj().T)
    sigma_n2_hat = max(float(np.min(np.linalg.eigvalsh(Rh)).real), 1e-8)

    # 1) Capon spectrum for support detection
    P_capon = capon_spectrum(Rhat, grid_deg, loading=1e-3)
    peak_mask = local_maxima_1d(P_capon)

    sec_lo, sec_hi = desired_sector
    in_sector = (grid_deg >= sec_lo) & (grid_deg <= sec_hi)

    # 2) desired steering estimate
    sector_peak_idx = np.where(peak_mask & in_sector & (P_capon > sigma_n2_hat))[0]
    if sector_peak_idx.size > 0:
        best_idx = sector_peak_idx[np.argmax(P_capon[sector_peak_idx])]
        a_hat = steering_vector(grid_deg[best_idx], M)
    else:
        a_hat = a_bar.copy()

    # 3) sparse support
    support_idx = np.where(peak_mask & (P_capon > sigma_n2_hat))[0]
    support_all_deg = grid_deg[support_idx]

    P_sparse = np.full_like(P_capon, 1e-12, dtype=float)

    if support_all_deg.size == 0:
        Ri = sigma_n2_hat * np.eye(M, dtype=complex)
        Rs = a_hat @ a_hat.conj().T
        a_hat = normalize_vec(a_hat)
        w = mvdr_weight(Ri, a_hat)
        info = SparseInfo(
            sigma_n2_hat=sigma_n2_hat,
            support_all_deg=np.array([]),
            support_interf_deg=np.array([]),
            powers_all=np.array([]),
            P_capon=P_capon,
            P_sparse=P_sparse,
        )
        return w, info, Rs, Ri, a_hat

    # 4) nonnegative LS power estimation
    powers_all = solve_power_ls_nonnegative(
        Rhat=Rhat,
        support_deg=support_all_deg,
        M=M,
        sigma_n2_hat=sigma_n2_hat,
        delta=delta,
    )

    for idx, pw in zip(support_idx, powers_all):
        P_sparse[idx] = max(float(pw), 1e-12)

    # 5) reconstruct Rs and Ri
    Rs = np.zeros((M, M), dtype=complex)
    Ri = sigma_n2_hat * np.eye(M, dtype=complex)

    support_interf_deg = []
    for th, pw in zip(support_all_deg, powers_all):
        a = steering_vector(th, M)
        if sec_lo <= th <= sec_hi:
            Rs += pw * (a @ a.conj().T)
        else:
            Ri += pw * (a @ a.conj().T)
            support_interf_deg.append(float(th))

    Rs = 0.5 * (Rs + Rs.conj().T)
    Ri = 0.5 * (Ri + Ri.conj().T)
    Ri += loading * max(np.trace(Ri).real / M, 1e-12) * np.eye(M)

    a_from_Rs = Rs @ a_bar
    if np.linalg.norm(a_from_Rs) > 1e-12:
        a_hat = normalize_vec(a_from_Rs)
    else:
        a_hat = normalize_vec(a_hat)

    w = mvdr_weight(Ri, a_hat)

    info = SparseInfo(
        sigma_n2_hat=sigma_n2_hat,
        support_all_deg=support_all_deg,
        support_interf_deg=np.array(support_interf_deg),
        powers_all=powers_all,
        P_capon=P_capon,
        P_sparse=P_sparse,
    )
    return w, info, Rs, Ri, a_hat
# ============================================================
# Baselines
# ============================================================
def sample_mvdr_beamformer(Rhat, a_bar):
    M = Rhat.shape[0]
    delta = 1e-3 * np.trace(Rhat).real / M
    Rdl = Rhat + delta * np.eye(M)
    return mvdr_weight(Rdl, a_bar)


def optimal_mvdr_beamformer(Ri_true, a_true):
    return mvdr_weight(Ri_true, a_true)


# ============================================================
# Plot helpers
# ============================================================
def stylize_axes(ax):
    ax.set_facecolor("white")
    ax.grid(True, linestyle="-", alpha=GRID_ALPHA)
    for side in ["top", "right"]:
        ax.spines[side].set_visible(False)
    for side in ["left", "bottom"]:
        ax.spines[side].set_linewidth(1.1)
    ax.tick_params(direction="out", length=5, width=1.0, pad=6)


def plot_single_run_spectra(grid_deg, spectra, meta, desired_sector, qh_theta_est=None):
    fig, ax = plt.subplots(figsize=(10.6, 5.6))

    # 先画算法曲线
    for name, P in spectra.items():
        P = np.asarray(P, dtype=float)
        P_db = 10.0 * np.log10(P / max(np.max(P), 1e-12) + 1e-12)

        st = METHOD_STYLES[name]
        ax.plot(
            grid_deg, P_db,
            color=st["color"],
            linestyle="-",
            linewidth=2.2 if name == "MP-INCM" else 1.8,
            label=name,
            zorder=3
        )

    # 扇区阴影：更淡
    ax.axvspan(
        desired_sector[0], desired_sector[1],
        color=COLORS["sector"], alpha=0.10, zorder=0, label="Desired sector"
    )

    # 参考线：更细，减少抢戏
    ax.axvline(meta["theta_s_true"], color=COLORS["true"],
               linestyle=":", linewidth=1.2, label="True SOI", zorder=2)

    ax.axvline(meta["theta_s_bar"], color=COLORS["presumed"],
               linestyle="-.", linewidth=1.2, label="Presumed SOI", zorder=2)

    for i, thi in enumerate(meta["theta_i_true"]):
        ax.axvline(thi, color="0.45", linestyle=":",
                   linewidth=1.0,
                   label="True interferer" if i == 0 else None,
                   zorder=2)

    if qh_theta_est is not None and len(qh_theta_est) > 0:
        for i, th in enumerate(qh_theta_est):
            ax.axvline(
                th, color=COLORS["est"],
                linestyle=(0, (2, 2)), linewidth=1.0, alpha=0.80,
                label="MP estimated angle" if i == 0 else None,
                zorder=2
            )

    ax.set_xlabel("Angle (deg)")
    ax.set_ylabel("Normalized spectrum (dB)")
    ax.set_xlim([-90, 90])

    # 关键改动：主图不要压到 -120
    ax.set_ylim([-60, 3])

    stylize_axes(ax)

    # 图例移到图外
    add_box_legend(
        ax,
        loc="upper left",
        bbox_to_anchor=(1.01, 1.00),
        borderaxespad=0.0,
        ncol=1
    )

    # -------- inset --------
    axins = inset_axes(ax, width="31%", height="31%", loc="lower left", borderpad=1.1)

    for name, P in spectra.items():
        P = np.asarray(P, dtype=float)
        P_db = 10.0 * np.log10(P / max(np.max(P), 1e-12) + 1e-12)
        st = METHOD_STYLES[name]
        axins.plot(
            grid_deg, P_db,
            color=st["color"],
            linestyle="-",
            linewidth=2.0 if name == "MP-INCM" else 1.6,
            zorder=3
        )

    axins.axvspan(
        desired_sector[0], desired_sector[1],
        color=COLORS["sector"], alpha=0.10, zorder=0
    )

    axins.axvline(meta["theta_s_true"], color=COLORS["true"], linestyle=":", linewidth=1.0)
    axins.axvline(meta["theta_s_bar"], color=COLORS["presumed"], linestyle="-.", linewidth=1.0)

    for thi in meta["theta_i_true"]:
        axins.axvline(thi, color="0.45", linestyle=":", linewidth=0.9)

    if qh_theta_est is not None and len(qh_theta_est) > 0:
        for th in qh_theta_est:
            axins.axvline(th, color=COLORS["est"], linestyle=(0, (2, 2)),
                          linewidth=0.9, alpha=0.80)

    axins.set_xlim(-4, 13)
    axins.set_ylim(-35, 3)
    axins.grid(axis="y", linestyle="-", alpha=0.10)
    axins.grid(axis="x", visible=False)
    axins.tick_params(labelsize=9, direction="out", length=3, width=0.7)

    for side in ["top", "right", "left", "bottom"]:
        axins.spines[side].set_linewidth(0.8)
        axins.spines[side].set_color("0.4")

    # 放大框和连线改成灰色、细线
    mark_inset(ax, axins, loc1=2, loc2=4, fc="none", ec="0.45", lw=0.8)

    fig.tight_layout()
    plt.subplots_adjust(right=0.80)
    save_current_figure("fig01_single_run_spectra")


def plot_single_run_beampattern(grid_deg, curves, meta):
    fig, ax = plt.subplots(figsize=(10.6, 5.6))

    key_names = [
        "Optimal MVDR", "MP-INCM", "Capon-INCM",
        "MEPS-INCM", "URGLQ-INCM", "PGLQ-INCM", "Sparse-INCM"
    ]

    for name in key_names:
        if name not in curves:
            continue
        st = METHOD_STYLES[name]
        ax.plot(
            grid_deg, curves[name],
            color=st["color"],
            linestyle="-",
            linewidth=2.2 if name == "MP-INCM" else 1.8,
            label=name,
            zorder=3
        )

    ax.axvline(meta["theta_s_true"], color=COLORS["true"],
               linestyle=":", linewidth=1.2, label="True SOI", zorder=2)

    for i, thi in enumerate(meta["theta_i_true"]):
        ax.axvline(thi, color="0.45", linestyle=":",
                   linewidth=1.0,
                   label="True interferer" if i == 0 else None,
                   zorder=2)

    ax.set_xlim([-90, 90])
    ax.set_ylim([-100, 2])
    ax.set_xlabel("Angle (deg)")
    ax.set_ylabel("Normalized beampattern (dB)")
    stylize_axes(ax)

    add_box_legend(
        ax,
        loc="upper left",
        bbox_to_anchor=(1.01, 1.00),
        borderaxespad=0.0
    )

    # inset
    x1, x2 = 24, 28.0
    y1, y2 = -100, -40

    axins = inset_axes(ax, width="30%", height="30%", loc="upper right", borderpad=1.0)

    for name in key_names:
        if name not in curves:
            continue
        st = METHOD_STYLES[name]
        axins.plot(
            grid_deg, curves[name],
            color=st["color"],
            linestyle="-",
            linewidth=2.0 if name == "MP-INCM" else 1.5,
            zorder=3
        )

    axins.axvline(meta["theta_s_true"], color=COLORS["true"], linestyle=":", linewidth=1.0)
    for thi in meta["theta_i_true"]:
        axins.axvline(thi, color="0.45", linestyle=":", linewidth=0.9)

    axins.set_xlim(x1, x2)
    axins.set_ylim(y1, y2)
    axins.grid(axis="y", linestyle="-", alpha=0.10)
    axins.grid(axis="x", visible=False)
    axins.tick_params(labelsize=9, direction="out", length=3, width=0.7)

    for side in ["top", "right", "left", "bottom"]:
        axins.spines[side].set_linewidth(0.8)
        axins.spines[side].set_color("0.4")

    mark_inset(ax, axins, loc1=2, loc2=4, fc="none", ec="0.45", lw=0.8)

    fig.tight_layout()
    plt.subplots_adjust(right=0.80)
    save_current_figure("fig02_single_run_beampattern")
def plot_curve(
    x, curves, xlabel, ylabel, title, filename_stem,
    add_inset=False,
    inset_xlim=None,
    inset_ylim=None,
    inset_loc="center left",
    inset_width="20%",
    inset_height="20%",
    inset_methods=None,
):
    fig, ax = plt.subplots(figsize=(10.4, 5.8))

    style_map = {
        "Optimal MVDR": dict(color=COLORS["optimal"], marker="o", lw=LINEWIDTH_REF),
        "MP-INCM": dict(color=COLORS["qh"], marker="o", lw=LINEWIDTH_MAIN),
        "Capon-INCM": dict(color=COLORS["capon"], marker="^", lw=LINEWIDTH_REF),
        "MEPS-INCM": dict(color=COLORS["meps"], marker="D", lw=LINEWIDTH_REF),
        "URGLQ-INCM": dict(color=COLORS["urglq"], marker="P", lw=LINEWIDTH_REF),
        "PGLQ-INCM": dict(color=COLORS["pglq"], marker="X", lw=LINEWIDTH_REF),
    }

    for name, y in curves.items():
        plot_method_curve(ax, x, y, name, use_markers=True)
    ax.set_xlabel(xlabel)
    ax.set_ylabel(ylabel)
    stylize_axes(ax)
    if filename_stem == "fig03_sinr_vs_snapshots":
        add_box_legend(ax, loc="lower right")
    else:
        add_box_legend(ax, loc="best")    # ===== inset zoom =====
    if add_inset and inset_xlim is not None and inset_ylim is not None:
        axins = inset_axes(
            ax,
            width=inset_width,
            height=inset_height,
            loc=inset_loc,
            borderpad=1.1
        )

        if inset_methods is None:
            inset_methods = list(curves.keys())

        for name in inset_methods:
            plot_method_curve(axins, x, curves[name], name, use_markers=True, label=None)
        axins.set_xlim(inset_xlim)
        axins.set_ylim(inset_ylim)
        axins.grid(True, linestyle="-", alpha=0.15)
        axins.tick_params(labelsize=10, direction="out", length=3, width=0.8)

        for side in ["top", "right", "left", "bottom"]:
            axins.spines[side].set_linewidth(1.0)

        mark_inset(ax, axins, loc1=2, loc2=4, fc="none", ec="black", lw=1.0)

    fig.tight_layout()
    save_current_figure(filename_stem)

# ============================================================
# Single run
# ============================================================
def single_run_demo(
    M=20,
    K=50,
    theta_s_bar=5.0,
    theta_i_bar=(-30.0, 25.0),
    desired_half_width=6.0,
    look_err_deg=3.0,
    snr_db=20.0,
    inr_db=25.0,
    seed=7,
    mismatch_type="coherent_scattering",
):
    desired_sector = (theta_s_bar - desired_half_width, theta_s_bar + desired_half_width)
    grid_deg = np.linspace(-90, 90, 3601)

    # 使用完整推荐参数生成数据
    X, Rhat, a_s_true, a_s_bar, Ri_true, Rs_true, meta = generate_snapshots(
        M=M,
        K=K,
        theta_s_bar=theta_s_bar,
        theta_i_bar=theta_i_bar,
        look_err_deg=look_err_deg,
        snr_db=snr_db,
        inr_db=inr_db,
        sigma_n2=1.0,
        seed=seed,
        mismatch_type=mismatch_type,
    )

    w_opt = optimal_mvdr_beamformer(Ri_true, a_s_true)
    w_qh, qh_info, Rs_qh, Ri_qh, _ = qh_ipnc_beamformer(
        Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, model_order=None, max_order=6
    )
    spec_qh = qh_info["spec"]
    w_cap, P_cap, Rs_cap, Ri_cap, _ = capon_ipnc_beamformer(
        Rhat, theta_s_bar, desired_sector, grid_deg, loading=1e-3
    )
    w_meps, meps_info, Rs_meps, Ri_meps, _ = meps_ipnc_beamformer(
        Rhat, theta_s_bar, desired_sector, alpha=5, S=20, loading=1e-3
    )
    theta_i1, theta_i2 = meta["theta_i_true"]
    ur_intervals = [
        (theta_i1 - 8.0, theta_i1 + 8.0),
        (theta_i2 - 8.0, theta_i2 + 8.0),
    ]
    w_ur, ur_info, Rs_ur, Ri_ur, _ = urglq_ipnc_beamformer(
        Rhat,
        theta_s_bar,
        desired_sector,
        interference_intervals=ur_intervals,
        grid_deg=grid_deg,
        glq_order=3,
    )
    w_pg, pg_info, Rs_pg, Ri_pg, _ = pglq_ipnc_beamformer(
        Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, Q=3, eig_energy_ratio=0.9, delta_zk_u=0.03
    )
    w_sp, sp_info, Rs_sp, Ri_sp, _ = sparse_ipnc_beamformer(
        Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, delta=1e-5
    )

    delta = 1e-3 * np.trace(Rhat).real / M
    Rinv_full = np.linalg.inv(Rhat + delta * np.eye(M))
    P_meps_full, _, _ = meps_spectrum_from_inverse(Rinv_full, grid_deg, M)

    print("\n================ Single Run ================")
    print(f"Output folder          : {os.path.abspath(OUTPUT_DIR)}")
    print(f"True SOI angle         : {meta['theta_s_true']:.3f} deg")
    print(f"Presumed SOI angle     : {meta['theta_s_bar']:.3f} deg")
    print(f"True interferers       : {np.round(meta['theta_i_true'], 3)}")
    print(f"QH auto order          : {spec_qh['model_order']}")
    print(f"MEPS: L={meps_info['L']}, S={meps_info['S']}")
    peaks = ur_info.get("peak_angles", None)
    if peaks is None:
        print("URGLQ peaks            : None")
    else:
        print(f"URGLQ peaks            : {np.round(np.asarray(peaks, dtype=float), 3)}")
        print(f"PGLQ: L={pg_info['L']}, g={pg_info['g']:.3f}, intervals={pg_info['num_intervals']}")
    print()

    rows = [
        ("Optimal MVDR", w_opt, None, None),
        ("MP-INCM", w_qh, Rs_qh, Ri_qh),
        ("Capon-INCM", w_cap, Rs_cap, Ri_cap),
        ("MEPS-INCM", w_meps, Rs_meps, Ri_meps),
        ("URGLQ-INCM", w_ur, Rs_ur, Ri_ur),
        ("PGLQ-INCM", w_pg, Rs_pg, Ri_pg),
        ("Sparse-INCM", w_sp, Rs_sp, Ri_sp),
    ]

    for name, w, Rs_hat, Ri_hat in rows:
        sinr = output_sinr_db(w, a_s_true, Ri_true, meta["sigma_s2"])
        if Rs_hat is None:
            print(f"{name:15s}: SINR = {sinr:8.3f} dB")
        else:
            err_rs = fro_rel_err(Rs_hat, Rs_true)
            err_ri = fro_rel_err(Ri_hat, Ri_true)
            print(f"{name:15s}: SINR = {sinr:8.3f} dB | relErr(Rs) = {err_rs:7.4f} | relErr(Ri) = {err_ri:7.4f}")

    spectra = {
        "MP-INCM": spec_qh["P_grid"],
        "Capon-INCM": P_cap,
        "MEPS-INCM": P_meps_full,
        "URGLQ-INCM": ur_info["P_tilde"],
        "PGLQ-INCM": pg_info["P_broad"],
        "Sparse-INCM": sp_info.P_sparse,
    }

    plot_single_run_spectra(
        grid_deg,
        spectra,
        meta,
        desired_sector,
        qh_theta_est=spec_qh["theta_est"],
    )

    curves = {
        "Optimal MVDR": beampattern_db(w_opt, M, grid_deg),
        "MP-INCM": beampattern_db(w_qh, M, grid_deg),
        "Capon-INCM": beampattern_db(w_cap, M, grid_deg),
        "MEPS-INCM": beampattern_db(w_meps, M, grid_deg),
        "URGLQ-INCM": beampattern_db(w_ur, M, grid_deg),
        "PGLQ-INCM": beampattern_db(w_pg, M, grid_deg),
        "Sparse-INCM": beampattern_db(w_sp, M, grid_deg),
    }
    plot_single_run_beampattern(grid_deg, curves, meta)
    plt.show()


# ============================================================
# Monte Carlo vs snapshots
# ============================================================
def monte_carlo_vs_snapshots(
    M=20,
    theta_s_bar=5.0,
    desired_half_width=6.0,
    K_list=(20, 30, 40, 50, 60, 70, 80, 90, 100),
    MC=100,
):
    desired_sector = (theta_s_bar - desired_half_width, theta_s_bar + desired_half_width)
    grid_deg = np.linspace(-90, 90, 721)

    method_names = ["Optimal MVDR", "MP-INCM", "Capon-INCM", "MEPS-INCM", "URGLQ-INCM", "PGLQ-INCM",
                    "Sparse-INCM"]
    sinr_curves = {k: [] for k in method_names}
    errRi_curves = {"MP-INCM": [], "Capon-INCM": [], "MEPS-INCM": [], "URGLQ-INCM": [], "PGLQ-INCM": [],
                    "Sparse-INCM": []}
    errRs_curves = {"MP-INCM": [], "Capon-INCM": [], "MEPS-INCM": [], "URGLQ-INCM": [], "PGLQ-INCM": [],
                    "Sparse-INCM": []}
    for K in K_list:
        rec_sinr = {k: [] for k in method_names}
        rec_errRi = {k: [] for k in errRi_curves}
        rec_errRs = {k: [] for k in errRs_curves}

        for mc in range(MC):
            X, Rhat, a_s_true, a_s_bar, Ri_true, Rs_true, meta = generate_snapshots(
                M=M, K=K,
                theta_s_bar=theta_s_bar,
                theta_i_bar=(-30.0, 25.0),
                look_err_deg=3.0,
                snr_db=20.0,
                inr_db=25.0,
                sigma_n2=1.0,
                seed=1000 * mc + K,
            )

            w_opt = optimal_mvdr_beamformer(Ri_true, a_s_true)
            w_scm = sample_mvdr_beamformer(Rhat, a_s_bar)
            w_qh, _, Rs_qh, Ri_qh, _ = qh_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, model_order=None, max_order=6
            )
            w_cap, _, Rs_cap, Ri_cap, _ = capon_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg, loading=1e-3
            )
            w_meps, _, Rs_meps, Ri_meps, _ = meps_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, alpha=5, S=20, loading=1e-3
            )
            theta_i1, theta_i2 = meta["theta_i_true"]
            ur_intervals = [
                (theta_i1 - 8.0, theta_i1 + 8.0),
                (theta_i2 - 8.0, theta_i2 + 8.0),
            ]
            w_ur, ur_info, Rs_ur, Ri_ur, _ = urglq_ipnc_beamformer(
                Rhat,
                theta_s_bar,
                desired_sector,
                interference_intervals=ur_intervals,
                grid_deg=grid_deg,
                glq_order=3,
            )
            w_pg, _, Rs_pg, Ri_pg, _ = pglq_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, Q=3, eig_energy_ratio=0.9, delta_zk_u=0.03
            )
            w_sp, _, Rs_sp, Ri_sp, _ = sparse_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, delta=1e-5
            )
            rec_sinr["Optimal MVDR"].append(output_sinr_db(w_opt, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["MP-INCM"].append(output_sinr_db(w_qh, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["Capon-INCM"].append(output_sinr_db(w_cap, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["MEPS-INCM"].append(output_sinr_db(w_meps, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["URGLQ-INCM"].append(output_sinr_db(w_ur, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["PGLQ-INCM"].append(output_sinr_db(w_pg, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["Sparse-INCM"].append(output_sinr_db(w_sp, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_errRi["Sparse-INCM"].append(fro_rel_err(Ri_sp, Ri_true))
            rec_errRs["Sparse-INCM"].append(fro_rel_err(Rs_sp, Rs_true))

            rec_errRi["MP-INCM"].append(fro_rel_err(Ri_qh, Ri_true))
            rec_errRi["Capon-INCM"].append(fro_rel_err(Ri_cap, Ri_true))
            rec_errRi["MEPS-INCM"].append(fro_rel_err(Ri_meps, Ri_true))
            rec_errRi["URGLQ-INCM"].append(fro_rel_err(Ri_ur, Ri_true))
            rec_errRi["PGLQ-INCM"].append(fro_rel_err(Ri_pg, Ri_true))

            rec_errRs["MP-INCM"].append(fro_rel_err(Rs_qh, Rs_true))
            rec_errRs["Capon-INCM"].append(fro_rel_err(Rs_cap, Rs_true))
            rec_errRs["MEPS-INCM"].append(fro_rel_err(Rs_meps, Rs_true))
            rec_errRs["URGLQ-INCM"].append(fro_rel_err(Rs_ur, Rs_true))
            rec_errRs["PGLQ-INCM"].append(fro_rel_err(Rs_pg, Rs_true))

        for k in method_names:
            sinr_curves[k].append(np.mean(rec_sinr[k]))
        for k in errRi_curves:
            errRi_curves[k].append(np.mean(rec_errRi[k]))
            errRs_curves[k].append(np.mean(rec_errRs[k]))

    plot_curve(
        K_list, sinr_curves,
        xlabel="Number of snapshots",
        ylabel="Average output SINR (dB)",
        title="Output SINR versus Number of Snapshots",
        filename_stem="fig03_sinr_vs_snapshots",
    )

    plot_curve(
        K_list, errRi_curves,
        xlabel="Number of snapshots",
        ylabel=r"Average relative error of $\hat{\mathbf{R}}_{i+n}$",
        title=r"Reconstruction Error of $\hat{\mathbf{R}}_{i+n}$ versus Number of Snapshots",
        filename_stem="fig04_Rin_error_vs_snapshots",
        add_inset=True,
        inset_xlim=(25, 30),
        inset_ylim=(0.985, 1.005),
        inset_loc="center left",
        inset_methods=["Capon-INCM", "URGLQ-INCM", "PGLQ-INCM", "MEPS-INCM"]
    )

    plot_curve(
        K_list, errRs_curves,
        xlabel="Number of snapshots",
        ylabel=r"Average relative error of $\hat{\mathbf{R}}_{s}$",
        title=r"Reconstruction Error of $\hat{\mathbf{R}}_{s}$ versus Number of Snapshots",
        filename_stem="fig05_Rs_error_vs_snapshots",
        add_inset=True,
        inset_xlim=(25, 30),
        inset_ylim=(0.988, 1.002),
        inset_loc="upper left",
        inset_methods=["Capon-INCM", "URGLQ-INCM", "PGLQ-INCM", "MEPS-INCM"]
    )

    plt.show()
    return sinr_curves, errRi_curves, errRs_curves
# ============================================================
# Runtime plot helpers
# ============================================================
def plot_runtime_curve(x, curves, xlabel, ylabel, filename_stem, logy=False):
    fig, ax = plt.subplots(figsize=(10.4, 5.8))

    style_map = {
        "MP-INCM": dict(color=COLORS["qh"], marker="o", lw=LINEWIDTH_MAIN),
        "Capon-INCM": dict(color=COLORS["capon"], marker="^", lw=LINEWIDTH_REF),
        "MEPS-INCM": dict(color=COLORS["meps"], marker="D", lw=LINEWIDTH_REF),
        "URGLQ-INCM": dict(color=COLORS["urglq"], marker="P", lw=LINEWIDTH_REF),
        "PGLQ-INCM": dict(color=COLORS["pglq"], marker="X", lw=LINEWIDTH_REF),
        "Sparse-INCM": dict(color=COLORS["sparse"], marker="v", lw=LINEWIDTH_REF),  # ← 新增这一行
    }

    for name, y in curves.items():
        style = style_map.get(name, dict(color=None, marker="o", lw=LINEWIDTH_REF))
        ax.plot(
            x, y,
            marker=style["marker"],
            linewidth=style["lw"],
            markersize=MARKERSIZE,
            color=style["color"],
            label=name
        )

    ax.set_xlabel(xlabel)
    ax.set_ylabel(ylabel)
    if logy:
        ax.set_yscale("log")

    stylize_axes(ax)
    add_box_legend(ax, loc="best")
    fig.tight_layout()
    save_current_figure(filename_stem)


def measure_runtime_ms(func, n_repeat=3, warmup=True):
    if warmup:
        _ = func()

    t0 = time.perf_counter()
    for _ in range(n_repeat):
        _ = func()
    t1 = time.perf_counter()

    return 1000.0 * (t1 - t0) / n_repeat


# ============================================================
# Monte Carlo runtime vs snapshots
# ============================================================
def monte_carlo_runtime_vs_snapshots(
    M=20,
    theta_s_bar=5.0,
    desired_half_width=6.0,
    K_list=(20, 30, 40, 50, 60, 70, 80, 90, 100),
    MC=100,
    n_repeat=3,
    grid_size=721,
):
    desired_sector = (theta_s_bar - desired_half_width, theta_s_bar + desired_half_width)
    grid_deg = np.linspace(-90, 90, grid_size)

    method_names = [ "MP-INCM", "Capon-INCM", "MEPS-INCM", "URGLQ-INCM", "PGLQ-INCM", "Sparse-INCM"]
    runtime_curves = {k: [] for k in method_names}

    for K in K_list:
        rec_runtime = {k: [] for k in method_names}

        for mc in range(MC):
            X, Rhat, a_s_true, a_s_bar, Ri_true, Rs_true, meta = generate_snapshots(
                M=M, K=K,
                theta_s_bar=theta_s_bar,
                theta_i_bar=(-30.0, 25.0),
                look_err_deg=3.0,
                snr_db=20.0,
                inr_db=25.0,
                sigma_n2=1.0,
                seed=3000 * mc + K,
            )

            method_funcs = {
                "MP-INCM": lambda: qh_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector,
                    grid_deg=grid_deg, model_order=None, max_order=6
                ),
                "Capon-INCM": lambda: capon_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector, grid_deg, loading=1e-3
                ),
                "Sparse-INCM": lambda: sparse_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, delta=1e-5
                ),
                "MEPS-INCM": lambda: meps_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector, alpha=5, S=20, loading=1e-3
                ),
                "URGLQ-INCM": lambda: urglq_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector,
                    grid_deg=grid_deg, num_interferers=2,
                    interference_half_width_deg=8.0, glq_order=3
                ),
                "PGLQ-INCM": lambda: pglq_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector,
                    grid_deg=grid_deg, Q=3,
                    eig_energy_ratio=0.9, delta_zk_u=0.03
                ),
            }

            for name, fn in method_funcs.items():
                rec_runtime[name].append(measure_runtime_ms(fn, n_repeat=n_repeat, warmup=True))

        for k in method_names:
            runtime_curves[k].append(np.mean(rec_runtime[k]))

    plot_runtime_curve(
        K_list, runtime_curves,
        xlabel="Number of snapshots",
        ylabel="Average runtime (ms)",
        filename_stem="fig09_runtime_vs_snapshots",
        logy=False
    )

    plot_runtime_curve(
        K_list, runtime_curves,
        xlabel="Number of snapshots",
        ylabel="Average runtime (ms, log scale)",
        filename_stem="fig10_runtime_vs_snapshots_log",
        logy=True
    )

    plt.show()
    return runtime_curves


# ============================================================
# Monte Carlo runtime vs number of sensors
# ============================================================
def monte_carlo_runtime_vs_sensors(
    M_list=(10, 15, 20, 25, 30, 35, 40, 50, 60, 70, 80, 90, 100),
    K=50,
    theta_s_bar=5.0,
    desired_half_width=6.0,
    MC=100,
    n_repeat=3,
    grid_size=721,
):
    desired_sector = (theta_s_bar - desired_half_width, theta_s_bar + desired_half_width)
    # 其余代码不变
    grid_deg = np.linspace(-90, 90, grid_size)

    method_names = [ "MP-INCM", "Capon-INCM", "MEPS-INCM", "URGLQ-INCM", "PGLQ-INCM", "Sparse-INCM"]
    runtime_curves = {k: [] for k in method_names}

    for M in M_list:
        rec_runtime = {k: [] for k in method_names}

        for mc in range(MC):
            X, Rhat, a_s_true, a_s_bar, Ri_true, Rs_true, meta = generate_snapshots(
                M=M, K=K,
                theta_s_bar=theta_s_bar,
                theta_i_bar=(-30.0, 25.0),
                look_err_deg=3.0,
                snr_db=20.0,
                inr_db=25.0,
                sigma_n2=1.0,
                seed=4000 * mc + M,
            )

            method_funcs = {
                "MP-INCM": lambda: qh_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector,
                    grid_deg=grid_deg, model_order=None, max_order=6
                ),
                "Capon-INCM": lambda: capon_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector, grid_deg, loading=1e-3
                ),
                "MEPS-INCM": lambda: meps_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector, alpha=5, S=20, loading=1e-3
                ),
                "Sparse-INCM": lambda: sparse_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, delta=1e-5
                ),
                "URGLQ-INCM": lambda: urglq_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector,
                    grid_deg=grid_deg, num_interferers=2,
                    interference_half_width_deg=8.0, glq_order=3
                ),
                "PGLQ-INCM": lambda: pglq_ipnc_beamformer(
                    Rhat, theta_s_bar, desired_sector,
                    grid_deg=grid_deg, Q=3,
                    eig_energy_ratio=0.9, delta_zk_u=0.03
                ),
            }

            for name, fn in method_funcs.items():
                rec_runtime[name].append(measure_runtime_ms(fn, n_repeat=n_repeat, warmup=True))

        for k in method_names:
            runtime_curves[k].append(np.mean(rec_runtime[k]))

    plot_runtime_curve(
        M_list, runtime_curves,
        xlabel="Number of sensors",
        ylabel="Average runtime (ms)",
        filename_stem="fig11_runtime_vs_sensors",
        logy=False
    )

    plot_runtime_curve(
        M_list, runtime_curves,
        xlabel="Number of sensors",
        ylabel="Average runtime (ms, log scale)",
        filename_stem="fig12_runtime_vs_sensors_log",
        logy=True
    )

    plt.show()
    return runtime_curves
# ============================================================
# Monte Carlo vs mismatch
# ============================================================
def monte_carlo_vs_look_error(
    M=20,
    K=50,
    theta_s_bar=5.0,
    desired_half_width=6.0,
    err_list=(0, 2, 4, 6, 8, 10, 12),
    MC=100,
):
    desired_sector = (theta_s_bar - desired_half_width, theta_s_bar + desired_half_width)
    # 其余代码不变
    grid_deg = np.linspace(-90, 90, 721)

    method_names = ["Optimal MVDR", "MP-INCM", "Capon-INCM", "MEPS-INCM", "URGLQ-INCM", "PGLQ-INCM",
                    "Sparse-INCM"]
    sinr_curves = {k: [] for k in method_names}
    errRi_curves = {"MP-INCM": [], "Capon-INCM": [], "MEPS-INCM": [], "URGLQ-INCM": [], "PGLQ-INCM": [],
                    "Sparse-INCM": []}
    errRs_curves = {"MP-INCM": [], "Capon-INCM": [], "MEPS-INCM": [], "URGLQ-INCM": [], "PGLQ-INCM": [],
                    "Sparse-INCM": []}
    for err in err_list:
        rec_sinr = {k: [] for k in method_names}
        rec_errRi = {k: [] for k in errRi_curves}
        rec_errRs = {k: [] for k in errRs_curves}

        for mc in range(MC):
            X, Rhat, a_s_true, a_s_bar, Ri_true, Rs_true, meta = generate_snapshots(
                M=M, K=K,
                theta_s_bar=theta_s_bar,
                theta_i_bar=(-30.0, 25.0),  # ← 已统一
                look_err_deg=err,  # 这里保留 err（这是 vs look error 的变量）
                snr_db=20.0,
                inr_db=25.0,  # ← 已统一
                sigma_n2=1.0,
                seed=2000 * mc + int(10 * err + K),
            )

            w_opt = optimal_mvdr_beamformer(Ri_true, a_s_true)
            w_scm = sample_mvdr_beamformer(Rhat, a_s_bar)
            w_qh, _, Rs_qh, Ri_qh, _ = qh_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, model_order=None, max_order=6
            )
            w_cap, _, Rs_cap, Ri_cap, _ = capon_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg, loading=1e-3
            )
            w_meps, _, Rs_meps, Ri_meps, _ = meps_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, alpha=5, S=20, loading=1e-3
            )
            theta_i1, theta_i2 = meta["theta_i_true"]
            ur_intervals = [
                (theta_i1 - 8.0, theta_i1 + 8.0),
                (theta_i2 - 8.0, theta_i2 + 8.0),
            ]
            w_ur, ur_info, Rs_ur, Ri_ur, _ = urglq_ipnc_beamformer(
                Rhat,
                theta_s_bar,
                desired_sector,
                interference_intervals=ur_intervals,
                grid_deg=grid_deg,
                glq_order=3,
            )
            w_pg, _, Rs_pg, Ri_pg, _ = pglq_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, Q=3, eig_energy_ratio=0.9, delta_zk_u=0.03
            )
            w_sp, _, Rs_sp, Ri_sp, _ = sparse_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg=grid_deg, delta=1e-5
            )

            rec_sinr["Sparse-INCM"].append(output_sinr_db(w_sp, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_errRi["Sparse-INCM"].append(fro_rel_err(Ri_sp, Ri_true))
            rec_errRs["Sparse-INCM"].append(fro_rel_err(Rs_sp, Rs_true))
            rec_sinr["Optimal MVDR"].append(output_sinr_db(w_opt, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["MP-INCM"].append(output_sinr_db(w_qh, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["Capon-INCM"].append(output_sinr_db(w_cap, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["MEPS-INCM"].append(output_sinr_db(w_meps, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["URGLQ-INCM"].append(output_sinr_db(w_ur, a_s_true, Ri_true, meta["sigma_s2"]))
            rec_sinr["PGLQ-INCM"].append(output_sinr_db(w_pg, a_s_true, Ri_true, meta["sigma_s2"]))

            rec_errRi["MP-INCM"].append(fro_rel_err(Ri_qh, Ri_true))
            rec_errRi["Capon-INCM"].append(fro_rel_err(Ri_cap, Ri_true))
            rec_errRi["MEPS-INCM"].append(fro_rel_err(Ri_meps, Ri_true))
            rec_errRi["URGLQ-INCM"].append(fro_rel_err(Ri_ur, Ri_true))
            rec_errRi["PGLQ-INCM"].append(fro_rel_err(Ri_pg, Ri_true))

            rec_errRs["MP-INCM"].append(fro_rel_err(Rs_qh, Rs_true))
            rec_errRs["Capon-INCM"].append(fro_rel_err(Rs_cap, Rs_true))
            rec_errRs["MEPS-INCM"].append(fro_rel_err(Rs_meps, Rs_true))
            rec_errRs["URGLQ-INCM"].append(fro_rel_err(Rs_ur, Rs_true))
            rec_errRs["PGLQ-INCM"].append(fro_rel_err(Rs_pg, Rs_true))

        for k in method_names:
            sinr_curves[k].append(np.mean(rec_sinr[k]))
        for k in errRi_curves:
            errRi_curves[k].append(np.mean(rec_errRi[k]))
            errRs_curves[k].append(np.mean(rec_errRs[k]))

    plot_curve(
        err_list, sinr_curves,
        xlabel="Look-direction mismatch range (deg)",
        ylabel="Average output SINR (dB)",
        title="Output SINR versus Look-Direction Mismatch Range",
        filename_stem="fig06_sinr_vs_mismatch"
    )

    plot_curve(
        err_list, errRi_curves,
        xlabel="Look-direction mismatch range (deg)",
        ylabel=r"Average relative error of $\hat{\mathbf{R}}_{i+n}$",
        title=r"Reconstruction Error of $\hat{\mathbf{R}}_{i+n}$ versus Mismatch Range",
        filename_stem="fig07_Rin_error_vs_mismatch",
        add_inset=True,
        inset_xlim=(0, 12),
        inset_ylim=(0.988, 1.002),
        inset_loc="lower left",
        inset_methods=["Capon-INCM", "URGLQ-INCM", "PGLQ-INCM"]
    )

    plot_curve(
        err_list, errRs_curves,
        xlabel="Look-direction mismatch range (deg)",
        ylabel=r"Average relative error of $\hat{\mathbf{R}}_{s}$",
        title=r"Reconstruction Error of $\hat{\mathbf{R}}_{s}$ versus Mismatch Range",
        filename_stem="fig08_Rs_error_vs_mismatch"
    )

    plt.show()
    return sinr_curves, errRi_curves, errRs_curves
def greedy_match_atoms(est_angles, est_powers, true_angles):
    est_angles = np.asarray(est_angles, dtype=float).reshape(-1)
    est_powers = np.asarray(est_powers, dtype=float).reshape(-1)
    true_angles = np.asarray(true_angles, dtype=float).reshape(-1)

    matched_angles = np.zeros_like(true_angles, dtype=float)
    matched_powers = np.zeros_like(true_angles, dtype=float)

    used = np.zeros(len(est_angles), dtype=bool)

    for k, th_true in enumerate(true_angles):
        avail = np.where(~used)[0]
        if avail.size == 0:
            matched_angles[k] = th_true
            matched_powers[k] = 1e-12
            continue

        j = avail[np.argmin(np.abs(est_angles[avail] - th_true))]
        used[j] = True
        matched_angles[k] = est_angles[j]
        matched_powers[k] = max(float(est_powers[j]), 1e-12)

    return matched_angles, matched_powers


def extract_qh_matched_atoms(spec_qh, meta, desired_sector):
    theta_est = np.asarray(spec_qh["theta_est"], dtype=float)
    power_est = np.asarray(spec_qh["power_est"], dtype=float)

    in_sector = (theta_est >= desired_sector[0]) & (theta_est <= desired_sector[1])

    # 目标
    theta_s_est, p_s_est = greedy_match_atoms(
        theta_est[in_sector],
        power_est[in_sector],
        np.array([meta["theta_s_true"]], dtype=float)
    )

    # 干扰
    theta_i_est, p_i_est = greedy_match_atoms(
        theta_est[~in_sector],
        power_est[~in_sector],
        np.asarray(meta["theta_i_true"], dtype=float)
    )

    return float(theta_s_est[0]), float(p_s_est[0]), theta_i_est, p_i_est


def build_beamformer_from_atoms(
    M,
    theta_s_bar,
    theta_s_atom,
    p_s_atom,
    theta_i_atoms,
    p_i_atoms,
    sigma_n2,
):
    a_bar = steering_vector(theta_s_bar, M)

    a_s = steering_vector(theta_s_atom, M)
    Rs = float(p_s_atom) * (a_s @ a_s.conj().T)

    Ri = float(sigma_n2) * np.eye(M, dtype=complex)
    for th, pw in zip(np.asarray(theta_i_atoms).reshape(-1), np.asarray(p_i_atoms).reshape(-1)):
        a_i = steering_vector(th, M)
        Ri += float(pw) * (a_i @ a_i.conj().T)

    Rs = 0.5 * (Rs + Rs.conj().T)
    Ri = 0.5 * (Ri + Ri.conj().T)

    a_hat = Rs @ a_bar
    if np.linalg.norm(a_hat) < 1e-12:
        a_hat = a_bar.copy()
    a_hat = normalize_vec(a_hat)

    w = mvdr_weight(Ri, a_hat)
    return w, Rs, Ri, a_hat


def monte_carlo_vs_input_snr(
        M=20,
        K=80,
        theta_s_bar=5.0,  # ← 统一
        theta_i_bar=(-30.0, 25.0),  # ← 统一
        desired_half_width=6.0,
        snr_list=(-5, 0, 5, 10, 15, 20),
        inr_db=25.0,  # ← 统一
        sigma_n2=1.0,
        look_err_deg=3.0,  # ← 统一
        MC=100,
        mismatch_type="look",
):
    desired_sector = (theta_s_bar - desired_half_width, theta_s_bar + desired_half_width)
    grid_deg = np.linspace(-90.0, 90.0, 721)

    # === 只保留这几个方法（删掉了两条 ablation 曲线）===
    method_names = [
        "Optimal MVDR",
        "MP-INCM",
        "Capon-INCM",
        "MEPS-INCM",
        "URGLQ-INCM",
        "PGLQ-INCM",
        "Sparse-INCM",
    ]
    sinr_curves = {name: [] for name in method_names}

    for snr_db in snr_list:
        rec_sinr = {name: [] for name in method_names}

        for mc in range(MC):
            X, Rhat, a_s_true, a_s_bar, Ri_true, Rs_true, meta = generate_snapshots(
                M=M,
                K=K,
                theta_s_bar=theta_s_bar,
                theta_i_bar=theta_i_bar,
                look_err_deg=look_err_deg,
                snr_db=snr_db,
                inr_db=inr_db,
                sigma_n2=sigma_n2,
                seed=1000 * mc + int(10 * (snr_db + 50)),
                mismatch_type=mismatch_type,
            )

            w_opt = optimal_mvdr_beamformer(Ri_true, a_s_true)

            # 只计算真实的 MP-INCM（不需要 ablation）
            w_qh, _, _, _, _ = qh_ipnc_beamformer(
                Rhat,
                theta_s_bar,
                desired_sector,
                grid_deg=grid_deg,
                model_order=None,
                max_order=6,
            )

            w_cap, _, _, _, _ = capon_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, grid_deg, loading=1e-3
            )
            w_meps, _, _, _, _ = meps_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector, alpha=5, S=20, loading=1e-3
            )

            theta_i1, theta_i2 = meta["theta_i_true"]
            ur_intervals = [
                (theta_i1 - 8.0, theta_i1 + 8.0),
                (theta_i2 - 8.0, theta_i2 + 8.0),
            ]
            w_ur, _, _, _, _ = urglq_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector,
                interference_intervals=ur_intervals,
                grid_deg=grid_deg, glq_order=3
            )

            w_pg, _, _, _, _ = pglq_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector,
                grid_deg=grid_deg, Q=3,
                eig_energy_ratio=0.9, delta_zk_u=0.03
            )

            w_sp, _, _, _, _ = sparse_ipnc_beamformer(
                Rhat, theta_s_bar, desired_sector,
                grid_deg=grid_deg, delta=1e-5
            )

            # 记录 SINR（不再记录两条 ablation 曲线）
            rec_sinr["Optimal MVDR"].append(
                output_sinr_db(w_opt, a_s_true, Ri_true, meta["sigma_s2"])
            )
            rec_sinr["MP-INCM"].append(
                output_sinr_db(w_qh, a_s_true, Ri_true, meta["sigma_s2"])
            )
            rec_sinr["Capon-INCM"].append(
                output_sinr_db(w_cap, a_s_true, Ri_true, meta["sigma_s2"])
            )
            rec_sinr["MEPS-INCM"].append(
                output_sinr_db(w_meps, a_s_true, Ri_true, meta["sigma_s2"])
            )
            rec_sinr["URGLQ-INCM"].append(
                output_sinr_db(w_ur, a_s_true, Ri_true, meta["sigma_s2"])
            )
            rec_sinr["PGLQ-INCM"].append(
                output_sinr_db(w_pg, a_s_true, Ri_true, meta["sigma_s2"])
            )
            rec_sinr["Sparse-INCM"].append(
                output_sinr_db(w_sp, a_s_true, Ri_true, meta["sigma_s2"])
            )

        for name in method_names:
            sinr_curves[name].append(np.mean(rec_sinr[name]))

    # 画图（现在只会显示 7 条曲线）
    # ==================== 画图（新增放大镜） ====================
    plot_curve(
        snr_list,
        sinr_curves,
        xlabel="Input SNR (dB)",
        ylabel="Average output SINR (dB)",
        title="Output SINR versus Input SNR",
        filename_stem="fig_sinr_vs_input_snr",

        # ==================== 新增：放大镜参数 ====================
        add_inset=True,  # 打开放大镜
        inset_xlim=(4.2, 5.2),  # 横轴放大范围（你可自行调整）
        inset_ylim=(14, 19),  # 纵轴放大范围（你可自行调整）
        inset_loc="lower right",  # 放大镜位置（可改：lower right / center right 等）
        inset_width="32%",  # 放大镜宽度
        inset_height="32%",  # 放大镜高度
        inset_methods=None  # None = 显示所有曲线（推荐）
    )
    return sinr_curves
if __name__ == "__main__":
    ensure_output_dir()
    monte_carlo_vs_input_snr(
        M=20,  # 文献中最常用的阵元数（20比30更标准）
        K=50,  # 快拍数适中，既能看出低快拍优势，又不计算太慢
        theta_s_bar=5.0,  # SOI 方向
        theta_i_bar=(-30.0, 25.0),  # 干扰角度拉得更开，更具代表性
        desired_half_width=6.0,  # 期望扇区半宽（6° 很合理）
        snr_list=(-5, 0, 5, 10, 15, 20),
        inr_db=25.0,  # 干扰强度提升到25dB（15dB太弱了，算法差异不明显）
        sigma_n2=1.0,
        look_err_deg=3.0,  # 指向误差3°（比4°稍小，但仍能体现鲁棒性）
        MC=100,
        mismatch_type="coherent_scattering",
    )

    # single_run_demo(seed=7, mismatch_type="coherent_scattering")

