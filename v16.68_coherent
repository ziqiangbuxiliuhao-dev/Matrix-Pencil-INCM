# ============================================================
# Basic utilities
# ============================================================
def steering_vector(theta_deg, M, d_over_lambda=0.5):
    theta_rad = np.deg2rad(theta_deg)
    m = np.arange(M)
    phase = -1j * 2.0 * np.pi * d_over_lambda * np.sin(theta_rad) * m
    return np.exp(phase).reshape(-1, 1)


def normalize_vec(a):
    nrm = np.linalg.norm(a)
    if nrm < 1e-12:
        return a
    return a / nrm


def sample_covariance(X):
    return X @ X.conj().T / X.shape[1]


def toeplitz_rectify(R):
    M = R.shape[0]
    Rt = np.zeros_like(R, dtype=complex)
    for k in range(-(M - 1), M):
        diag_mean = np.mean(np.diagonal(R, offset=k))
        idx = np.arange(M - abs(k))
        if k >= 0:
            Rt[idx, idx + k] = diag_mean
        else:
            Rt[idx - k, idx] = diag_mean
    Rt = 0.5 * (Rt + Rt.conj().T)
    return Rt


def mvdr_weight(Ri, a):
    M = Ri.shape[0]
    Ri = 0.5 * (Ri + Ri.conj().T)
    delta = 1e-6 * np.trace(Ri).real / M
    Ri = Ri + delta * np.eye(M)

    x = np.linalg.solve(Ri, a)
    denom = (a.conj().T @ x).item()
    if np.abs(denom) < 1e-12:
        denom = 1e-12
    return x / denom


def output_sinr_db(w, a_s, Ri_true, sigma_s2):
    num = sigma_s2 * np.abs((w.conj().T @ a_s).item()) ** 2
    den = np.real((w.conj().T @ Ri_true @ w).item())
    val = max(num / max(den, 1e-12), 1e-12)
    return 10.0 * np.log10(val)


def fro_rel_err(A, B):
    return np.linalg.norm(A - B, "fro") / max(np.linalg.norm(B, "fro"), 1e-12)


def beampattern_db(w, M, grid_deg):
    P = np.zeros_like(grid_deg, dtype=float)
    for i, th in enumerate(grid_deg):
        a = steering_vector(th, M)
        P[i] = np.abs((w.conj().T @ a).item()) ** 2
    P = P / max(np.max(P), 1e-12)
    return 10.0 * np.log10(P + 1e-12)

def steering_vector_gain_phase(theta_deg, M, rng,
                               d_over_lambda=0.5,
                               gain_std=0.05,
                               phase_std=0.025*np.pi):
    """
    Gain/phase perturbed actual steering vector.
    Nominal manifold is still steering_vector(theta_deg, M).
    """
    a = steering_vector(theta_deg, M, d_over_lambda=d_over_lambda).reshape(-1)

    gamma = rng.normal(0.0, gain_std, size=M)      # gain perturbation
    delta = rng.normal(0.0, phase_std, size=M)     # phase perturbation

    g = (1.0 + gamma) * np.exp(1j * delta)
    a_tilde = g * a

    return a_tilde.reshape(-1, 1)

def steering_vector_coherent_scattering(
    theta0_deg,
    M,
    rng,
    d_over_lambda=0.5,
    num_scatterers=4,
    scatter_half_width_deg=2.0,
    scatter_amp=1.0,
    direct_amp=1.0,
    normalize_norm=True,
):
    """
    Coherent local scattering model:
    a_eff = direct_amp * a(theta0) + sum_q beta_q * a(theta_q)

    - scatterers are located around theta0
    - beta_q are fixed complex coefficients within one Monte Carlo run
    - this is coherent scattering because all paths share the same waveform
    """

    a_eff = direct_amp * steering_vector(theta0_deg, M, d_over_lambda=d_over_lambda)

    scatter_angles = theta0_deg + rng.uniform(
        -scatter_half_width_deg,
        scatter_half_width_deg,
        size=num_scatterers
    )

    # fixed complex path coefficients in one run
    mags = (scatter_amp / np.sqrt(max(num_scatterers, 1))) * (
        0.8 + 0.4 * rng.random(num_scatterers)
    )
    phases = rng.uniform(0.0, 2.0 * np.pi, size=num_scatterers)
    betas = mags * np.exp(1j * phases)

    for beta, th in zip(betas, scatter_angles):
        a_eff += beta * steering_vector(th, M, d_over_lambda=d_over_lambda)

    if normalize_norm:
        a_eff = np.sqrt(M) * a_eff / max(np.linalg.norm(a_eff), 1e-12)

    return a_eff.reshape(-1, 1), scatter_angles, betas
def steering_vector_random_error(theta_deg, M, rng,
                                 d_over_lambda=0.5,
                                 rho_max=np.sqrt(0.3),
                                 preserve_norm=True):
    """
    Actual steering vector with additive random steering-vector error.
    """
    a = steering_vector(theta_deg, M, d_over_lambda=d_over_lambda).reshape(-1)

    rho = rng.uniform(0.0, rho_max)
    phi = rng.uniform(0.0, 2*np.pi, size=M)

    xi = (rho / np.sqrt(M)) * np.exp(1j * phi)
    a_tilde = a + xi

    if preserve_norm:
        a_tilde = np.sqrt(M) * a_tilde / max(np.linalg.norm(a_tilde), 1e-12)

    return a_tilde.reshape(-1, 1)
# ============================================================
# Simulation model
# ============================================================
def generate_snapshots(
    M=20,
    K=50,
    theta_s_bar=5.0,
    theta_i_bar=(-30.0, 25.0),
    look_err_deg=3.0,
    snr_db=20.0,
    inr_db=25.0,
    sigma_n2=1.0,
    seed=0,

    # mismatch control
    mismatch_type="look",              # "look", "gain_phase", "random_sv", "coherent_scattering"
    apply_mismatch_to_interferers=True,

    # gain/phase perturbation parameters
    gain_std=0.05,
    phase_std=0.025 * np.pi,

    # random steering-vector error parameter
    rho_max=np.sqrt(0.3),

    # coherent local scattering parameters
    num_scatterers=4,
    scatter_half_width_deg=2.0,
    scatter_amp=1.0,
    direct_amp=1.0,
):
    rng = np.random.default_rng(seed)

    theta_s_true = theta_s_bar + rng.uniform(-look_err_deg, look_err_deg)
    theta_i_true = np.array(theta_i_bar) + rng.uniform(-look_err_deg, look_err_deg, size=2)

    sigma_s2 = 10 ** (snr_db / 10.0) * sigma_n2
    sigma_i2 = np.ones(2) * (10 ** (inr_db / 10.0) * sigma_n2)

    a_s_bar = steering_vector(theta_s_bar, M)

    if mismatch_type == "look":
        a_s_true = steering_vector(theta_s_true, M)

        if apply_mismatch_to_interferers:
            A_i_true = [steering_vector(th, M) for th in theta_i_true]
        else:
            A_i_true = [steering_vector(th0, M) for th0 in theta_i_bar]

    elif mismatch_type == "gain_phase":
        a_s_true = steering_vector_gain_phase(
            theta_s_true, M, rng,
            gain_std=gain_std,
            phase_std=phase_std
        )

        if apply_mismatch_to_interferers:
            A_i_true = [
                steering_vector_gain_phase(
                    th, M, rng,
                    gain_std=gain_std,
                    phase_std=phase_std
                )
                for th in theta_i_true
            ]
        else:
            A_i_true = [steering_vector(th, M) for th in theta_i_true]

    elif mismatch_type == "random_sv":
        a_s_true = steering_vector_random_error(
            theta_s_true, M, rng,
            rho_max=rho_max
        )

        if apply_mismatch_to_interferers:
            A_i_true = [
                steering_vector_random_error(
                    th, M, rng,
                    rho_max=rho_max
                )
                for th in theta_i_true
            ]
        else:
            A_i_true = [steering_vector(th, M) for th in theta_i_true]

    elif mismatch_type == "coherent_scattering":
        a_s_true, theta_s_scat, beta_s = steering_vector_coherent_scattering(
            theta_s_true,
            M,
            rng,
            num_scatterers=num_scatterers,
            scatter_half_width_deg=scatter_half_width_deg,
            scatter_amp=scatter_amp,
            direct_amp=direct_amp,
            normalize_norm=True,
        )

        # for a clean limitation analysis, keep interferers unchanged first
        A_i_true = [steering_vector(th, M) for th in theta_i_true]

    else:
        raise ValueError(f"Unknown mismatch_type: {mismatch_type}")

    s = np.sqrt(sigma_s2) * (
        rng.standard_normal(K) + 1j * rng.standard_normal(K)
    ) / np.sqrt(2)

    interferences = [
        np.sqrt(pw) * (rng.standard_normal(K) + 1j * rng.standard_normal(K)) / np.sqrt(2)
        for pw in sigma_i2
    ]

    noise = np.sqrt(sigma_n2) * (
        rng.standard_normal((M, K)) + 1j * rng.standard_normal((M, K))
    ) / np.sqrt(2)

    X = a_s_true @ s.reshape(1, -1)
    for a_i, i_sig in zip(A_i_true, interferences):
        X += a_i @ i_sig.reshape(1, -1)
    X += noise

    Rhat = sample_covariance(X)

    Rs_true = sigma_s2 * (a_s_true @ a_s_true.conj().T)

    Ri_true = sigma_n2 * np.eye(M, dtype=complex)
    for a_i, pw in zip(A_i_true, sigma_i2):
        Ri_true += pw * (a_i @ a_i.conj().T)

    meta = {
        "theta_s_true": theta_s_true,
        "theta_i_true": theta_i_true,
        "theta_s_bar": theta_s_bar,
        "sigma_s2": sigma_s2,
        "sigma_i2": sigma_i2,
        "sigma_n2": sigma_n2,
        "mismatch_type": mismatch_type,
        "apply_mismatch_to_interferers": apply_mismatch_to_interferers,
        "gain_std": gain_std,
        "phase_std": phase_std,
        "rho_max": rho_max,
        "num_scatterers": num_scatterers,
        "scatter_half_width_deg": scatter_half_width_deg,
        "scatter_amp": scatter_amp,
        "direct_amp": direct_amp,
    }

    if mismatch_type == "coherent_scattering":
        meta["theta_s_scat"] = theta_s_scat
        meta["beta_s"] = beta_s

    return X, Rhat, a_s_true, a_s_bar, Ri_true, Rs_true, meta
    # ------------------------------------------------------------
    # 3) snapshot generation
    # ------------------------------------------------------------
    s = np.sqrt(sigma_s2) * (
        rng.standard_normal(K) + 1j * rng.standard_normal(K)
    ) / np.sqrt(2)

    interferences = [
        np.sqrt(pw) * (rng.standard_normal(K) + 1j * rng.standard_normal(K)) / np.sqrt(2)
        for pw in sigma_i2
    ]

    noise = np.sqrt(sigma_n2) * (
        rng.standard_normal((M, K)) + 1j * rng.standard_normal((M, K))
    ) / np.sqrt(2)

    X = a_s_true @ s.reshape(1, -1)
    for a_i, i_sig in zip(A_i_true, interferences):
        X += a_i @ i_sig.reshape(1, -1)
    X += noise

    Rhat = sample_covariance(X)

    # true desired covariance
    Rs_true = sigma_s2 * (a_s_true @ a_s_true.conj().T)

    # true interference-plus-noise covariance
    Ri_true = sigma_n2 * np.eye(M, dtype=complex)
    for a_i, pw in zip(A_i_true, sigma_i2):
        Ri_true += pw * (a_i @ a_i.conj().T)

    meta = {
        "theta_s_true": theta_s_true,
        "theta_i_true": theta_i_true,
        "theta_s_bar": theta_s_bar,
        "sigma_s2": sigma_s2,
        "sigma_i2": sigma_i2,
        "sigma_n2": sigma_n2,
        "mismatch_type": mismatch_type,
        "apply_mismatch_to_interferers": apply_mismatch_to_interferers,
        "gain_std": gain_std,
        "phase_std": phase_std,
        "rho_max": rho_max,
    }

    return X, Rhat, a_s_true, a_s_bar, Ri_true, Rs_true, meta

# ============================================================
# Common grid reconstruction
# ============================================================
def reconstruct_from_grid_spectrum(grid_deg, P, M, desired_sector, noise_floor=1e-8):
    theta1, theta2 = desired_sector
    dth = np.deg2rad(grid_deg[1] - grid_deg[0])

    Rs = np.zeros((M, M), dtype=complex)
    Ri = np.zeros((M, M), dtype=complex)

    for th, pw in zip(grid_deg, P):
        a = steering_vector(th, M)
        if theta1 <= th <= theta2:
            Rs += pw * (a @ a.conj().T) * dth
        else:
            Ri += pw * (a @ a.conj().T) * dth

    Ri += noise_floor * np.eye(M)
    Rs = 0.5 * (Rs + Rs.conj().T)
    Ri = 0.5 * (Ri + Ri.conj().T)
    return Rs, Ri

# ============================================================
# Common grid reconstruction
# ============================================================
def reconstruct_from_grid_spectrum(grid_deg, P, M, desired_sector, noise_floor=1e-8):
    theta1, theta2 = desired_sector
    dth = np.deg2rad(grid_deg[1] - grid_deg[0])

    Rs = np.zeros((M, M), dtype=complex)
    Ri = np.zeros((M, M), dtype=complex)

    for th, pw in zip(grid_deg, P):
        a = steering_vector(th, M)
        if theta1 <= th <= theta2:
            Rs += pw * (a @ a.conj().T) * dth
        else:
            Ri += pw * (a @ a.conj().T) * dth

    Ri += noise_floor * np.eye(M)
    Rs = 0.5 * (Rs + Rs.conj().T)
    Ri = 0.5 * (Ri + Ri.conj().T)
    return Rs, Ri


def capon_spectrum_from_inverse(Rinv, grid_deg, M):
    P = np.zeros_like(grid_deg, dtype=float)
    for i, th in enumerate(grid_deg):
        a = steering_vector(th, M)
        den = np.real((a.conj().T @ Rinv @ a).item())
        P[i] = 1.0 / max(den, 1e-12)
    return P


def safe_inverse(R, loading_scale=1e-6):
    M = R.shape[0]
    R = 0.5 * (R + R.conj().T)
    delta = loading_scale * max(np.trace(R).real / M, 1e-12)
    return np.linalg.inv(R + delta * np.eye(M))


def estimate_noise_power(R):
    evals = np.linalg.eigvalsh(0.5 * (R + R.conj().T))
    return max(float(np.min(np.real(evals))), 1e-8)


def find_top_spectrum_peaks(grid_deg, P, exclude_sector=None, num_peaks=2, min_sep_deg=6.0):
    mask = np.ones_like(grid_deg, dtype=bool)
    if exclude_sector is not None:
        mask &= (grid_deg < exclude_sector[0]) | (grid_deg > exclude_sector[1])

    cand = []
    for i in range(1, len(grid_deg) - 1):
        if not mask[i]:
            continue
        if P[i] >= P[i - 1] and P[i] >= P[i + 1]:
            cand.append(i)

    if not cand:
        cand = list(np.where(mask)[0])

    cand = sorted(cand, key=lambda i: P[i], reverse=True)
    chosen = []
    for idx in cand:
        th = grid_deg[idx]
        if all(abs(th - c) >= min_sep_deg for c in chosen):
            chosen.append(float(th))
        if len(chosen) >= num_peaks:
            break

    return chosen


def merge_intervals(intervals):
    intervals = [(float(a), float(b)) for a, b in intervals if b > a]
    if not intervals:
        return []
    intervals.sort()
    merged = [list(intervals[0])]
    for a, b in intervals[1:]:
        if a <= merged[-1][1] + 1e-9:
            merged[-1][1] = max(merged[-1][1], b)
        else:
            merged.append([a, b])
    return [tuple(x) for x in merged]


def clip_interval_against_sector(a_deg, b_deg, desired_sector):
    t1, t2 = desired_sector
    out = []
    a_deg, b_deg = float(a_deg), float(b_deg)
    if b_deg <= a_deg:
        return out
    if b_deg <= t1 or a_deg >= t2:
        return [(a_deg, b_deg)]
    if a_deg < t1:
        out.append((a_deg, min(b_deg, t1)))
    if b_deg > t2:
        out.append((max(a_deg, t2), b_deg))
    return out


def intervals_from_peak_windows(peak_angles, half_width_deg, desired_sector, angle_limits=(-90.0, 90.0)):
    intervals = []
    lo, hi = angle_limits
    for pk in peak_angles:
        a = max(lo, pk - half_width_deg)
        b = min(hi, pk + half_width_deg)
        intervals.extend(clip_interval_against_sector(a, b, desired_sector))
    return merge_intervals(intervals)


def gauss_legendre_matrix_integral(Rinv, M, intervals_deg, Q=3):
    z, w = np.polynomial.legendre.leggauss(Q)
    R = np.zeros((M, M), dtype=complex)
    for a_deg, b_deg in intervals_deg:
        a_rad = np.deg2rad(a_deg)
        b_rad = np.deg2rad(b_deg)
        mid = 0.5 * (a_rad + b_rad)
        half = 0.5 * (b_rad - a_rad)
        for zi, wi in zip(z, w):
            th_deg = np.rad2deg(mid + half * zi)
            a = steering_vector(th_deg, M)
            den = np.real((a.conj().T @ Rinv @ a).item())
            pw = 1.0 / max(den, 1e-12)
            R += wi * pw * (a @ a.conj().T) * half
    return 0.5 * (R + R.conj().T)


def estimate_steering_by_sector_scan(Ri, desired_sector, M, n_grid=181):
    grid = np.linspace(desired_sector[0], desired_sector[1], n_grid)
    Rinv = safe_inverse(Ri, loading_scale=1e-6)
    P = capon_spectrum_from_inverse(Rinv, grid, M)
    th = float(grid[np.argmax(P)])
    return normalize_vec(steering_vector(th, M)), th, P

def project_to_hpd(R, floor_ratio=1e-6):
    R = 0.5 * (R + R.conj().T)
    evals, evecs = np.linalg.eigh(R)
    floor = floor_ratio * max(np.max(np.real(evals)), 1.0)
    evals = np.maximum(np.real(evals), floor)
    return evecs @ np.diag(evals) @ evecs.conj().T


def estimate_steering_qcqp(Ri, a_bar, eps=1e-6, relax=1e-6):
    M = Ri.shape[0]
    a0 = a_bar.flatten().astype(complex)

    # 1) 先把 Ri 投影到 Hermitian PSD，避免数值假不可行
    Ri_psd = project_to_hpd(Ri, floor_ratio=1e-6)

    # 2) 更稳的逆矩阵
    Ri_inv = np.linalg.inv(Ri_psd + eps * np.eye(M, dtype=complex))

    # 3) 变量
    er = cp.Variable(M)
    ei = cp.Variable(M)
    e = er + 1j * ei
    a_new = a0 + e

    # 4) 目标
    objective = cp.real(cp.quad_form(a_new, Ri_inv))

    # 5) 约束：给一点松弛量，别卡在边界上
    rhs = float(np.real(a0.conj().T @ Ri_psd @ a0))
    constraints = [
        cp.real(a0.conj().T @ e) == 0,
        cp.imag(a0.conj().T @ e) == 0,
        cp.real(cp.quad_form(a_new, Ri_psd)) <= rhs + relax * max(abs(rhs), 1.0)
    ]

    prob = cp.Problem(cp.Minimize(objective), constraints)

    try:
        if "SCS" in cp.installed_solvers():
            prob.solve(solver=cp.SCS, verbose=False, max_iters=8000, eps=1e-5)
        elif "ECOS" in cp.installed_solvers():
            prob.solve(solver=cp.ECOS, verbose=False, max_iters=1000)
        else:
            print(f"[QCQP] No suitable solver found: {cp.installed_solvers()}")
            return normalize_vec(a0).reshape(-1, 1)

        if prob.status in ["optimal", "optimal_inaccurate"] and er.value is not None and ei.value is not None:
            e_opt = er.value + 1j * ei.value
            a_hat = a0 + e_opt
            return normalize_vec(a_hat).reshape(-1, 1)

        print(f"[QCQP] status = {prob.status}, fallback to presumed vector")

    except Exception as ex:
        print(f"[QCQP] Solve failed: {ex}, fallback to presumed vector")

    return normalize_vec(a0).reshape(-1, 1)
def build_pglq_theta_intervals(desired_sector, delta_interval_u):
    t1, t2 = desired_sector
    u_segments = [(-1.0, np.sin(np.deg2rad(t1))), (np.sin(np.deg2rad(t2)), 1.0)]
    intervals = []
    for ua, ub in u_segments:
        if ub <= ua:
            continue
        n_parts = max(1, int(np.ceil((ub - ua) / max(delta_interval_u, 1e-6))))
        edges_u = np.linspace(ua, ub, n_parts + 1)
        edges_th = np.rad2deg(np.arcsin(np.clip(edges_u, -1.0, 1.0)))
        intervals.extend((edges_th[i], edges_th[i + 1]) for i in range(n_parts))
    return intervals


def build_taper_matrix(M, delta_zk_u):
    idx = np.arange(M)
    diff = idx[:, None] - idx[None, :]
    T = np.ones((M, M), dtype=float)
    mask = diff != 0
    x = diff.astype(float) * float(delta_zk_u)
    T[mask] = np.sin(x[mask]) / x[mask]
    return T


def auxiliary_desired_covariance(Rinv, M, desired_sector, Q=5):
    return gauss_legendre_matrix_integral(Rinv, M, [desired_sector], Q=Q)
# ============================================================
# Capon-IPNC
# ============================================================
def capon_spectrum(Rhat, grid_deg, loading=1e-3):
    M = Rhat.shape[0]
    delta = loading * np.trace(Rhat).real / M
    Rdl = Rhat + delta * np.eye(M)
    Rinv = np.linalg.inv(Rdl)
    return capon_spectrum_from_inverse(Rinv, grid_deg, M)

# ============================================================
# URGLQ-IPNC
# ============================================================
def urglq_ipnc_beamformer(
    Rhat,
    theta_s_bar,
    desired_sector,
    interference_intervals=None,
    grid_deg=None,
    glq_order=3,
    num_interferers=2,
    interference_half_width_deg=8.0,
):
    if grid_deg is None:
        grid_deg = np.linspace(-90.0, 90.0, 721)

    M = Rhat.shape[0]
    a_bar = steering_vector(theta_s_bar, M)
    I = np.eye(M, dtype=complex)

    alpha = 100.0 * np.trace(Rhat).real
    C = alpha * (a_bar @ a_bar.conj().T) + I
    evals_c, evecs_c = np.linalg.eigh(0.5 * (C + C.conj().T))
    p1 = evecs_c[:, np.argmax(evals_c)].reshape(-1, 1)
    B = I - p1 @ p1.conj().T

    sigma_n2_est = estimate_noise_power(Rhat)
    R_tilde = B.conj().T @ Rhat @ B + sigma_n2_est * I
    Rinv_tilde = safe_inverse(R_tilde, loading_scale=1e-6)

    P_tilde = capon_spectrum_from_inverse(Rinv_tilde, grid_deg, M)

    if interference_intervals is None:
        peak_angles = find_top_spectrum_peaks(
            grid_deg,
            P_tilde,
            exclude_sector=desired_sector,
            num_peaks=num_interferers,
            min_sep_deg=interference_half_width_deg / 1.5,
        )
        intervals = intervals_from_peak_windows(
            peak_angles,
            half_width_deg=interference_half_width_deg,
            desired_sector=desired_sector,
        )
        if not intervals:
            intervals = [(-90.0, desired_sector[0]), (desired_sector[1], 90.0)]
    else:
        peak_angles = None
        intervals = interference_intervals

    Ri = gauss_legendre_matrix_integral(Rinv_tilde, M, intervals, Q=glq_order)
    Ri += sigma_n2_est * I
    Ri = 0.5 * (Ri + Ri.conj().T)

    Rinv_full = safe_inverse(Rhat, loading_scale=1e-3)
    Rs = auxiliary_desired_covariance(Rinv_full, M, desired_sector, Q=5)

    a_hat = estimate_steering_qcqp(Ri, a_bar)
    theta_hat = None
    P_sig = None
    w = mvdr_weight(Ri, a_hat)

    info = {
        "alpha": alpha,
        "sigma_n2_est": sigma_n2_est,
        "peak_angles": peak_angles,
        "intervals": intervals,
        "theta_hat": theta_hat,
        "P_tilde": P_tilde,
        "P_sig_scan": P_sig,
    }
    return w, info, Rs, Ri, a_hat


# ============================================================
# PGLQ-IPNC
# ============================================================
def pglq_ipnc_beamformer(
    Rhat,
    theta_s_bar,
    desired_sector,
    grid_deg=None,
    Q=3,
    eig_energy_ratio=0.9,
    delta_zk_u=0.03,
    g_candidates=None,
):
    if grid_deg is None:
        grid_deg = np.linspace(-90.0, 90.0, 721)
    if g_candidates is None:
        g_candidates = np.linspace(0.0, 1.6, 33)

    M = Rhat.shape[0]
    a_bar = steering_vector(theta_s_bar, M)
    I = np.eye(M, dtype=complex)

    Rh = 0.5 * (Rhat + Rhat.conj().T)
    evals, evecs = np.linalg.eigh(Rh)
    order = np.argsort(evals)[::-1]
    evals = np.real(evals[order])
    evecs = evecs[:, order]
    cum_ratio = np.cumsum(np.maximum(evals, 0.0)) / max(np.sum(np.maximum(evals, 0.0)), 1e-12)
    L = int(np.searchsorted(cum_ratio, eig_energy_ratio) + 1)
    L = max(1, min(L, M))
    Us = evecs[:, :L]
    Ps = Us @ Us.conj().T

    P_capon = capon_spectrum(Rhat, grid_deg, loading=1e-3)
    peak_angles = find_top_spectrum_peaks(
        grid_deg, P_capon, exclude_sector=desired_sector, num_peaks=2, min_sep_deg=6.0
    )
    T = build_taper_matrix(M, delta_zk_u)

    target_vals = []
    Rinv_base = safe_inverse(Rhat, loading_scale=1e-3)
    for th in peak_angles:
        a = steering_vector(th, M)
        target_vals.append(1.0 / max(np.real((a.conj().T @ Rinv_base @ a).item()), 1e-12))
    target_log = np.mean(np.log(np.maximum(target_vals, 1e-12))) if target_vals else 0.0

    best = None
    for g in g_candidates:
        A = I + g * Ps
        R_d = A @ Rhat @ A.conj().T
        R_t = 0.5 * ((R_d * T) + (R_d * T).conj().T)
        Rinv_t = safe_inverse(R_t, loading_scale=1e-6)
        vals = []
        for th in peak_angles:
            a = steering_vector(th, M)
            vals.append(1.0 / max(np.real((a.conj().T @ Rinv_t @ a).item()), 1e-12))
        cur_log = np.mean(np.log(np.maximum(vals, 1e-12))) if vals else 0.0
        err = abs(cur_log - target_log)
        if best is None or err < best[0]:
            best = (err, float(g), R_t, Rinv_t)

    _, g_opt, R_t, Rinv_t = best

    z, _ = np.polynomial.legendre.leggauss(Q)
    delta_z = np.max(np.diff(z)) if len(z) > 1 else 2.0
    delta_interval_u = 2.0 * delta_zk_u / max(delta_z, 1e-6)
    theta_intervals = build_pglq_theta_intervals(desired_sector, delta_interval_u)

    Ri = gauss_legendre_matrix_integral(Rinv_t, M, theta_intervals, Q=Q)
    Ri += estimate_noise_power(R_t) * I
    Ri = 0.5 * (Ri + Ri.conj().T)

    Rs = auxiliary_desired_covariance(Rinv_t, M, desired_sector, Q=max(Q, 5))
    a_hat = Rs @ a_bar
    if np.linalg.norm(a_hat) < 1e-12:
        a_hat = a_bar.copy()
    a_hat = normalize_vec(a_hat)

    w = mvdr_weight(Ri, a_hat)
    P_broad = capon_spectrum_from_inverse(Rinv_t, grid_deg, M)

    info = {
        "L": L,
        "g": g_opt,
        "delta_zk_u": delta_zk_u,
        "delta_interval_u": delta_interval_u,
        "num_intervals": len(theta_intervals),
        "peak_angles": peak_angles,
        "P_broad": P_broad,
    }
    return w, info, Rs, Ri, a_hat
# ============================================================
# Capon-IPNC
# ============================================================
def capon_spectrum(Rhat, grid_deg, loading=1e-3):
    M = Rhat.shape[0]
    delta = loading * np.trace(Rhat).real / M
    Rdl = Rhat + delta * np.eye(M)
    Rinv = np.linalg.inv(Rdl)

    P = np.zeros_like(grid_deg, dtype=float)
    for i, th in enumerate(grid_deg):
        a = steering_vector(th, M)
        den = np.real((a.conj().T @ Rinv @ a).item())
        P[i] = 1.0 / max(den, 1e-12)
    return P


def capon_ipnc_beamformer(Rhat, theta_s_bar, desired_sector, grid_deg, loading=1e-3):
    M = Rhat.shape[0]
    a_bar = steering_vector(theta_s_bar, M)

    P_capon = capon_spectrum(Rhat, grid_deg, loading=loading)
    Rs, Ri = reconstruct_from_grid_spectrum(grid_deg, P_capon, M, desired_sector)

    a_hat = Rs @ a_bar
    if np.linalg.norm(a_hat) < 1e-12:
        a_hat = a_bar.copy()
    a_hat = normalize_vec(a_hat)

    w = mvdr_weight(Ri, a_hat)
    return w, P_capon, Rs, Ri, a_hat


# ============================================================
# MEPS-IPNC
# ============================================================
def meps_spectrum_from_inverse(Rinv, grid_deg, M):
    u1 = np.zeros((M, 1), dtype=complex)
    u1[0, 0] = 1.0

    gamma_p = 1.0 / np.real((u1.T @ Rinv @ u1).item())
    gamma_p = max(gamma_p, 1e-12)

    v = Rinv @ u1

    P = np.zeros_like(grid_deg, dtype=float)
    for i, th in enumerate(grid_deg):
        a = steering_vector(th, M)
        z = (a.conj().T @ v).item()
        den = gamma_p * (np.abs(z) ** 2)
        P[i] = 1.0 / max(den, 1e-12)

    return P, gamma_p, v


def meps_ipnc_beamformer(
    Rhat,
    theta_s_bar,
    desired_sector,
    alpha=5,
    S=20,
    loading=1e-3,
):
    M = Rhat.shape[0]
    a_bar = steering_vector(theta_s_bar, M)

    L = int(alpha * M)
    delta = loading * np.trace(Rhat).real / M
    Rdl = Rhat + delta * np.eye(M)
    Rinv = np.linalg.inv(Rdl)

    grid_all = np.linspace(-90.0, 90.0, L)
    mask_ipn = (grid_all < desired_sector[0]) | (grid_all > desired_sector[1])
    grid_ipn = grid_all[mask_ipn]

    P_ipn, gamma_p, v = meps_spectrum_from_inverse(Rinv, grid_ipn, M)
    dth_ipn = np.deg2rad(grid_ipn[1] - grid_ipn[0])

    Ri = np.zeros((M, M), dtype=complex)
    for th, pw in zip(grid_ipn, P_ipn):
        a = steering_vector(th, M)
        Ri += pw * (a @ a.conj().T) * dth_ipn
    Ri = 0.5 * (Ri + Ri.conj().T)
    Ri += 1e-8 * np.eye(M)

    grid_sig = np.linspace(desired_sector[0], desired_sector[1], S)
    P_sig, _, _ = meps_spectrum_from_inverse(Rinv, grid_sig, M)
    dth_sig = np.deg2rad(grid_sig[1] - grid_sig[0])

    Rs = np.zeros((M, M), dtype=complex)
    for th, pw in zip(grid_sig, P_sig):
        a = steering_vector(th, M)
        Rs += pw * (a @ a.conj().T) * dth_sig
    Rs = 0.5 * (Rs + Rs.conj().T)

    a_hat = Rs @ a_bar
    if np.linalg.norm(a_hat) < 1e-12:
        a_hat = a_bar.copy()
    a_hat = normalize_vec(a_hat)

    w = mvdr_weight(Ri, a_hat)

    info = {
        "gamma_p": gamma_p,
        "Rinv_u1": v,
        "L": L,
        "S": S,
    }
    return w, info, Rs, Ri, a_hat


# ============================================================
# QH-PSE-IPNC
# ============================================================
def build_hankel_pair(seq, L=None):
    x = np.asarray(seq, dtype=complex).reshape(-1)
    N = len(x)

    if L is None:
        L = N // 2

    L = int(max(2, min(L, N - 2)))
    K = N - L

    Y0 = np.array([x[i:i + K] for i in range(L)], dtype=complex)
    Y1 = np.array([x[i + 1:i + K + 1] for i in range(L)], dtype=complex)
    return Y0, Y1, L, K


def auto_select_order_from_svals(svals, max_order=8, min_rel_level=1e-3):
    svals = np.asarray(svals, dtype=float).reshape(-1)
    if len(svals) < 2:
        return 1

    max_order = min(max_order, len(svals) - 1)
    s = svals[:max_order + 1]

    valid = (s[:-1] / max(s[0], 1e-12)) > min_rel_level
    candidate_idx = np.where(valid)[0]
    if len(candidate_idx) == 0:
        return 1

    gaps = s[:-1] / np.maximum(s[1:], 1e-12)
    best_local = candidate_idx[np.argmax(gaps[candidate_idx])]
    return int(best_local + 1)


def matrix_pencil_poles_from_seq(seq, order, L=None):
    Y0, Y1, L, K = build_hankel_pair(seq, L=L)
    U, svals, Vh = np.linalg.svd(Y0, full_matrices=False)

    order = int(max(1, min(order, len(svals), U.shape[1], Vh.shape[0])))

    Ur = U[:, :order]
    Vr = Vh.conj().T[:, :order]
    Sr = svals[:order]

    Sinv_sqrt = np.diag(1.0 / np.sqrt(np.maximum(Sr, 1e-12)))
    Z = Sinv_sqrt @ (Ur.conj().T @ Y1 @ Vr) @ Sinv_sqrt

    poles, _ = np.linalg.eig(Z)
    poles = poles / np.maximum(np.abs(poles), 1e-12)
    return poles, svals


def qh_pse_spectrum_from_covariance(
    Rhat,
    model_order=None,
    max_order=8,
    grid_deg=None,
    kernel_width_deg=1.2,
):
    M = Rhat.shape[0]
    if grid_deg is None:
        grid_deg = np.linspace(-90, 90, 721)

    delta = 1e-4 * np.trace(Rhat).real / M
    Rt = toeplitz_rectify(Rhat + delta * np.eye(M))

    r = Rt[:, 0].copy()
    seq = r[1:]

    Y0, _, L, _ = build_hankel_pair(seq, L=None)
    _, svals0, _ = np.linalg.svd(Y0, full_matrices=False)

    if model_order is None:
        order_hat = auto_select_order_from_svals(
            svals0,
            max_order=max_order,
            min_rel_level=1e-3
        )
    else:
        order_hat = int(model_order)

    poles, svals = matrix_pencil_poles_from_seq(seq, order=order_hat, L=L)

    u_est = -np.angle(poles) / np.pi
    valid = np.abs(u_est) <= 1.0
    poles = poles[valid]
    u_est = u_est[valid]
    theta_est = np.rad2deg(np.arcsin(np.clip(u_est, -1.0, 1.0)))

    lags = np.arange(1, M)
    if len(poles) > 0:
        V = poles[None, :] ** lags[:, None]
        amp_est, *_ = np.linalg.lstsq(V, seq, rcond=None)
        power_est = np.maximum(np.real(amp_est), 0.0)
    else:
        power_est = np.array([])

    if power_est.size > 0 and np.max(power_est) > 0:
        keep = power_est > 1e-4 * np.max(power_est)
        theta_est = theta_est[keep]
        power_est = power_est[keep]

    sigma_n2_est = max(np.real(r[0]) - np.sum(power_est), 1e-8)

    P_grid = np.zeros_like(grid_deg, dtype=float)
    for th, pw in zip(theta_est, power_est):
        P_grid += pw * np.exp(-0.5 * ((grid_deg - th) / kernel_width_deg) ** 2)
    P_grid += sigma_n2_est * 1e-3

    spec = {
        "theta_est": theta_est,
        "power_est": power_est,
        "sigma_n2_est": sigma_n2_est,
        "singular_values": svals,
        "model_order": order_hat,
        "P_grid": P_grid,
    }
    return spec

def covariance_reconstruction_cost(Rhat, support_deg, powers, sigma_n2_hat, M):
    Rm = sigma_n2_hat * np.eye(M, dtype=complex)
    for th, pw in zip(np.asarray(support_deg).reshape(-1), np.asarray(powers).reshape(-1)):
        a = steering_vector(th, M)
        Rm += float(pw) * (a @ a.conj().T)
    Rm = 0.5 * (Rm + Rm.conj().T)
    Rh = 0.5 * (Rhat + Rhat.conj().T)
    return np.linalg.norm(Rh - Rm, "fro")


def refine_qh_angles(
    Rhat,
    init_support_deg,
    desired_sector,
    sigma_n2_hat=None,
    n_iter=3,
    search_half_width_deg=2.0,
    search_step_deg=0.05,
    min_sep_deg=2.0,
):
    M = Rhat.shape[0]
    support = np.asarray(init_support_deg, dtype=float).copy()

    if sigma_n2_hat is None:
        sigma_n2_hat = estimate_noise_power(Rhat)

    # 默认第 1 个是目标，其余是干扰
    for _ in range(n_iter):
        for k in range(len(support)):
            cur = support[k]

            if k == 0:
                lo = max(desired_sector[0], cur - search_half_width_deg)
                hi = min(desired_sector[1], cur + search_half_width_deg)
            else:
                lo = cur - search_half_width_deg
                hi = cur + search_half_width_deg

            grid = np.arange(lo, hi + 0.5 * search_step_deg, search_step_deg)

            best_th = cur
            best_cost = np.inf

            for th in grid:
                cand = support.copy()
                cand[k] = th

                # 保证干扰不要跑进目标扇区
                if k >= 1 and (desired_sector[0] <= th <= desired_sector[1]):
                    continue

                # 最小间隔约束
                ok = True
                for j in range(len(cand)):
                    if j != k and abs(cand[j] - cand[k]) < min_sep_deg:
                        ok = False
                        break
                if not ok:
                    continue

                p_hat = solve_power_ls_nonnegative(
                    Rhat=Rhat,
                    support_deg=cand,
                    M=M,
                    sigma_n2_hat=sigma_n2_hat,
                    delta=1e-6,
                )

                cost = covariance_reconstruction_cost(
                    Rhat=Rhat,
                    support_deg=cand,
                    powers=p_hat,
                    sigma_n2_hat=sigma_n2_hat,
                    M=M,
                )

                if cost < best_cost:
                    best_cost = cost
                    best_th = th

            support[k] = best_th

        search_half_width_deg *= 0.6
        search_step_deg *= 0.6

    p_hat = solve_power_ls_nonnegative(
        Rhat=Rhat,
        support_deg=support,
        M=M,
        sigma_n2_hat=sigma_n2_hat,
        delta=1e-6,
    )

    return support, p_hat, sigma_n2_hat
def select_qh_angles(spec_qh, desired_sector, theta_s_bar, num_interf=2):
    theta_est = np.asarray(spec_qh["theta_est"], dtype=float)
    power_est = np.asarray(spec_qh["power_est"], dtype=float)

    in_sector = (theta_est >= desired_sector[0]) & (theta_est <= desired_sector[1])

    # 目标：优先选扇区内离 theta_s_bar 最近的
    theta_sig = theta_est[in_sector]
    power_sig = power_est[in_sector]

    if theta_sig.size > 0:
        i_sig = np.argmin(np.abs(theta_sig - theta_s_bar))
        theta_s = float(theta_sig[i_sig])
    else:
        theta_s = float(theta_s_bar)

    # 干扰：扇区外按功率从大到小选 num_interf 个
    theta_int = theta_est[~in_sector]
    power_int = power_est[~in_sector]

    if theta_int.size > 0:
        idx = np.argsort(power_int)[::-1][:num_interf]
        theta_i = theta_int[idx]
    else:
        theta_i = np.array([], dtype=float)

    return theta_s, np.asarray(theta_i, dtype=float)
