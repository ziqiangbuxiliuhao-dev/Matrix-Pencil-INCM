    ax.plot(
        x, y,
        color=st["color"],
        linestyle=st["ls"],
        linewidth=st["lw"],
        marker=marker,
        markersize=MARKERSIZE if marker is not None else 0,
        markerfacecolor="white" if marker is not None else None,
        markeredgecolor=st["color"] if marker is not None else None,
        markeredgewidth=1.0 if marker is not None else 0.0,
        label=name if label is None else label
    )
