def cov_atom(theta_deg, M):
    a = steering_vector(theta_deg, M)
    return a @ a.conj().T
def residual_excluding_k(Rhat, support_deg, powers, sigma_n2_hat, k, M):
    E = Rhat - sigma_n2_hat * np.eye(M, dtype=complex)
    for j, (th, pw) in enumerate(zip(support_deg, powers)):
        if j == k:
            continue
        E -= float(pw) * cov_atom(th, M)
    return 0.5 * (E + E.conj().T)
def single_angle_score(theta_deg, E, M):
    a = steering_vector(theta_deg, M)
    return np.real((a.conj().T @ E @ a).item())
def local_peak_search(E, theta0, M, lo, hi, step_deg=0.2):
    grid = np.arange(lo, hi + 0.5 * step_deg, step_deg)
    vals = [single_angle_score(th, E, M) for th in grid]
    return float(grid[np.argmax(vals)])
def score_prime_fd(theta_deg, E, M, h=0.02):
    return (single_angle_score(theta_deg + h, E, M) -
            single_angle_score(theta_deg - h, E, M)) / (2*h)

def score_hess_fd(theta_deg, E, M, h=0.02):
    return (single_angle_score(theta_deg + h, E, M) -
            2*single_angle_score(theta_deg, E, M) +
            single_angle_score(theta_deg - h, E, M)) / (h*h)

def newton_refine_single_angle(theta0, E, M, lo, hi, n_steps=2):
    th = float(np.clip(theta0, lo, hi))
    for _ in range(n_steps):
        g = score_prime_fd(th, E, M)
        H = score_hess_fd(th, E, M)
        if abs(H) < 1e-8:
            break
        th_new = th - g / H
        th = float(np.clip(th_new, lo, hi))
    return th
def refine_qh_angles_nomp(
    Rhat,
    init_support_deg,
    desired_sector,
    theta_s_bar,
    sigma_n2_hat=None,
    n_outer=2,
    target_half_width_deg=2.0,
    interf_half_width_deg=4.0,
    coarse_step_deg=0.2,
    newton_steps=2,
    min_sep_deg=2.0,
):
    M = Rhat.shape[0]
    support = np.asarray(init_support_deg, dtype=float).copy()

    if sigma_n2_hat is None:
        sigma_n2_hat = estimate_noise_power(Rhat)

    powers = solve_power_ls_nonnegative(
        Rhat=Rhat,
        support_deg=support,
        M=M,
        sigma_n2_hat=sigma_n2_hat,
        delta=1e-6,
    )

    sec_lo, sec_hi = desired_sector

    for _ in range(n_outer):
        for k in range(len(support)):
            E = residual_excluding_k(
                Rhat=Rhat,
                support_deg=support,
                powers=powers,
                sigma_n2_hat=sigma_n2_hat,
                k=k,
                M=M,
            )

            th0 = support[k]

            if k == 0:
                lo = max(sec_lo, th0 - target_half_width_deg)
                hi = min(sec_hi, th0 + target_half_width_deg)
            else:
                lo = max(-89.0, th0 - interf_half_width_deg)
                hi = min(89.0, th0 + interf_half_width_deg)

            # 先粗搜
            th1 = local_peak_search(E, th0, M, lo, hi, step_deg=coarse_step_deg)

            # 再牛顿细修
            th2 = newton_refine_single_angle(th1, E, M, lo, hi, n_steps=newton_steps)

            # 简单约束：最小角间隔
            ok = True
            for j in range(len(support)):
                if j != k and abs(th2 - support[j]) < min_sep_deg:
                    ok = False
                    break
            if ok:
                # 干扰不要进目标扇区
                if not (k >= 1 and sec_lo <= th2 <= sec_hi):
                    support[k] = th2

        # 每轮只做一次 NNLS
        powers = solve_power_ls_nonnegative(
            Rhat=Rhat,
            support_deg=support,
            M=M,
            sigma_n2_hat=sigma_n2_hat,
            delta=1e-6,
        )

    return support, powers, sigma_n2_hat
